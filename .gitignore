# Health runtime artifacts — regenerated by pipeline.health
tool/health/*.md
tool/health/open/*
!tool/health/open/.gitkeep
tool/health/artifacts/*
!tool/health/artifacts/.gitkeep

# Local Claude Code settings (machine-specific)
.claude/settings.local.json

# Internal-only — not part of the public webapp
team/
.claude/
tool/health/

# Private user state (CRITICAL — never commit)
user/
!user/.gitkeep

# Personal export bundles (Claude memory, history, configs)
_transfer_*/

# Editor / OS
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# Compatibility symlink into /opt/venv (container infra)
/venv

# Thesis stress reports (generated)
user/thesis-stress-report.md

# URL health-check report (generated by scripts/check_urls.py)
scripts/url_check_report.txt

# Network-view pipeline runtime artifacts
network/**/individual_*/run_*/
network/**/combined_*/run_*/
network/dashboard_prep/changes_*/
network/dashboard_prep/timeline/state/
network/scripts/run_check_*.md
network/scripts/*_proposals.md
