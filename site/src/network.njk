      <label><input type="checkbox" data-itype="vc" checked> <span class="lg-shape lg-dot lg-vc"></span> VC / private funds</label>
      <label><input type="checkbox" data-itype="foundation" checked> <span class="lg-shape lg-dot lg-foundation"></span> Foundations</label>
      <label><input type="checkbox" data-itype="family-office" checked> <span class="lg-shape lg-dot lg-family"></span> Family offices</label>
      <label><input type="checkbox" data-itype="government" checked> <span class="lg-shape lg-dot lg-government"></span> Government</label>
      <label><input type="checkbox" data-itype="other" checked> <span class="lg-shape lg-dot lg-other"></span> Other</label>
    </fieldset>

