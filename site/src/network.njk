      <label><input type="checkbox" data-rel="coinvest" checked> <span class="lg-shape lg-cell lg-cell-coinvest"></span> Co-investments via portcos</label>
    </fieldset>

    <fieldset class="ctrl-group ctrl-funds">
      <legend>Funds</legend>
