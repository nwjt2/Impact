          <span class="ctrl-fund-section-title">Non-INGO-Backed Funds</span>
          <span class="ctrl-fund-count" id="ctrl-fund-non-count"></span>
        </summary>
        <div class="ctrl-fund-shortcuts">
          <button type="button" data-fund-bulk="non:all">All</button>
          <button type="button" data-fund-bulk="non:none">None</button>
        </div>
        <div class="ctrl-fund-list" id="ctrl-fund-list-non"></div>
      </details>
    </fieldset>

    <fieldset class="ctrl-group ctrl-search">
      <legend>Find by name</legend>
      <input type="search" id="filter-search" placeholder="e.g. Gates, BII, Soros" />
    </fieldset>

    <fieldset class="ctrl-group ctrl-radio" id="ctrl-row-filter">
      <legend>Show investors</legend>
      <label><input type="radio" name="rowfilter" value="all" checked> All</label>
      <label><input type="radio" name="rowfilter" value="multi"> In 2+ funds</label>
    </fieldset>
  </div>

  <div id="selection-info" class="muted"></div>

  <div class="vis-wrap" style="height:75vh; min-height:600px;">
    <svg id="vis-svg" width="100%" height="100%"></svg>
    <div id="vis-tooltip"></div>
    <div id="vis-loading" role="status" aria-live="polite">
      <div class="vis-loading-spinner" aria-hidden="true"></div>
      <div>Drawing the network…</div>
    </div>
  </div>

  <div id="node-details" class="network-details" hidden></div>
</section>

<script src="https://unpkg.com/d3@7.9.0/dist/d3.min.js"></script>
<script src="https://unpkg.com/d3-sankey@0.12.3/dist/d3-sankey.min.js"></script>
<script src="{{ '/assets/js/network-data.js' | url }}"></script>

<script>
  // -----------------------------------------------------------
  // Data prep — collapse the cytoscape-shaped graph into the
  // shape the matrix and chord views actually want.
  //
  // Source: window.NETWORK = { nodes, edges, stats }.
  // We build:
  //   - investors: [{id, name, archetype, lp_funds:Set, coinvest_funds:Map(fund -> portco_count)}]
  //   - funds:     [{id, name, ingo_backed, lp_count, coinvest_count}]
  //   - cells[fundId][investorId] = { lp:bool, coinvest:Number }
  // -----------------------------------------------------------

  const NETWORK = window.NETWORK;
  if (!NETWORK) {
    document.getElementById('vis-loading')?.classList.add('hidden');
    document.getElementById('vis-svg').innerHTML =
      '<text x="20" y="40" fill="#fa3" font-size="14">network-data.js failed to load. Run python -m network.dashboard_prep.prep_scripts.build_network_json and rebuild.</text>';
    throw new Error('NETWORK data not loaded');
  }

  // Archetype palette — distinct enough that "other" doesn't read as
  // an empty cell. Empty cells are NOT drawn (the matrix background is
  // the empty state) so any visible square is signal.
  const ARCHETYPE_COLOR = {
    'dfi':           '#e25c5c',
    'vc':            '#3ed7b3',
    'foundation':    '#d6b94a',
    'family-office': '#b86bdf',
    'government':    '#4a9cd6',
    'other':         '#6c8aac',
  };

  function prep() {
    const nodesById = new Map(NETWORK.nodes.map(n => [n.id, n]));

    const allFunds = NETWORK.nodes
      .filter(n => n.type === 'fund')
      .map(n => ({
        id: n.id,
        name: n.name,
        ingo_backed: !!n.ingo_slug,
      }));

    // portco -> set(fund) (a portco may belong to multiple funds in theory; usually 1)
    const portcoToFunds = new Map();
    for (const e of NETWORK.edges) {
      if (e.kind === 'investment') {
        if (!portcoToFunds.has(e.target)) portcoToFunds.set(e.target, new Set());
        portcoToFunds.get(e.target).add(e.source);
      }
    }

    // For each investor, build LP set and co-invest map (fund -> # portcos)
    const investorLpFunds = new Map();
    const investorCoinvestFunds = new Map();
    for (const e of NETWORK.edges) {
      if (e.kind === 'lp') {
        if (!investorLpFunds.has(e.source)) investorLpFunds.set(e.source, new Set());
        investorLpFunds.get(e.source).add(e.target);
      } else if (e.kind === 'co-investor') {
        const funds = portcoToFunds.get(e.target);
        if (!funds) continue;
        if (!investorCoinvestFunds.has(e.source)) investorCoinvestFunds.set(e.source, new Map());
        const m = investorCoinvestFunds.get(e.source);
        for (const fundId of funds) {
          m.set(fundId, (m.get(fundId) || 0) + 1);
        }
      }
    }

    const investorIds = new Set([...investorLpFunds.keys(), ...investorCoinvestFunds.keys()]);
    const investors = [...investorIds].map(id => {
      const node = nodesById.get(id);
      const lpFunds = investorLpFunds.get(id) || new Set();
      const coFunds = investorCoinvestFunds.get(id) || new Map();
      const allFundIds = new Set([...lpFunds, ...coFunds.keys()]);
      return {
        id,
        name: node?.name || id,
        archetype: node?.investor_type || 'other',
        lp_funds: lpFunds,
        coinvest_funds: coFunds,
        all_funds: allFundIds,
        total_count: allFundIds.size,
      };
    });

    // Per-fund summary counts
    const fundLpCount = new Map();
    const fundCoinvestCount = new Map();
    for (const inv of investors) {
      for (const f of inv.lp_funds) {
        fundLpCount.set(f, (fundLpCount.get(f) || 0) + 1);
      }
      for (const f of inv.coinvest_funds.keys()) {
        fundCoinvestCount.set(f, (fundCoinvestCount.get(f) || 0) + 1);
      }
    }
    for (const f of allFunds) {
      f.lp_count = fundLpCount.get(f.id) || 0;
      f.coinvest_count = fundCoinvestCount.get(f.id) || 0;
      f.total_count = f.lp_count + f.coinvest_count;
    }

    return { funds: allFunds, investors };
  }

  const DATA = prep();

  // -----------------------------------------------------------
  // UI state
  // -----------------------------------------------------------
  const STATE = {
    view: 'matrix',
    enabledTypes: new Set(['dfi', 'vc', 'foundation', 'family-office', 'government', 'other']),
    enabledRel: { lp: true, coinvest: true },
    ingoOnly: false,
    onlyWithData: true,
    rowFilter: 'all',
    search: '',
    enabledFunds: new Set(DATA.funds.map(f => f.id)),  // all on by default
    hot: { investorId: null, fundId: null, pair: null, nodeIdx: null, linkIdx: null },
  };

  // Compute filtered fund/investor lists per current state.
  function computeFilteredLists() {
    let funds = DATA.funds.slice();
    funds = funds.filter(f => STATE.enabledFunds.has(f.id));
    if (STATE.ingoOnly) funds = funds.filter(f => f.ingo_backed);
    if (STATE.onlyWithData) funds = funds.filter(f => f.total_count > 0);

    let investors = DATA.investors.filter(inv => STATE.enabledTypes.has(inv.archetype));

    if (!STATE.enabledRel.lp && !STATE.enabledRel.coinvest) {
      investors = [];
    }

    // Investor must touch at least one of the visible funds via an enabled relationship.
    const fundIds = new Set(funds.map(f => f.id));
    investors = investors.filter(inv => {
      let touch = false;
      if (STATE.enabledRel.lp) {
        for (const f of inv.lp_funds) if (fundIds.has(f)) { touch = true; break; }
      }
      if (!touch && STATE.enabledRel.coinvest) {
        for (const f of inv.coinvest_funds.keys()) if (fundIds.has(f)) { touch = true; break; }
      }
      return touch;
    });

    if (STATE.rowFilter === 'multi') {
      investors = investors.filter(inv => {
        let count = 0;
        if (STATE.enabledRel.lp) {
          for (const f of inv.lp_funds) if (fundIds.has(f)) count++;
        }
        if (STATE.enabledRel.coinvest) {
          for (const f of inv.coinvest_funds.keys()) {
            if (fundIds.has(f) && (!STATE.enabledRel.lp || !inv.lp_funds.has(f))) count++;
          }
        }
        return count >= 2;
      });
    }

    if (STATE.search) {
      const q = STATE.search.toLowerCase();
      investors = investors.filter(inv => inv.name.toLowerCase().includes(q));
    }

    // Sort funds: INGO first, then by total_count desc, then alphabetical.
    funds.sort((a, b) => {
      if (a.ingo_backed !== b.ingo_backed) return a.ingo_backed ? -1 : 1;
      if (a.total_count !== b.total_count) return b.total_count - a.total_count;
      return a.name.localeCompare(b.name);
    });

    // Sort investors: by # of cells they fill in the *visible* fund set, desc.
    investors.forEach(inv => {
      let visCount = 0;
      for (const f of inv.lp_funds) if (fundIds.has(f) && STATE.enabledRel.lp) visCount++;
      for (const f of inv.coinvest_funds.keys()) {
        if (fundIds.has(f) && STATE.enabledRel.coinvest && (!STATE.enabledRel.lp || !inv.lp_funds.has(f))) visCount++;
      }
      inv._visCount = visCount;
    });
    investors.sort((a, b) => {
      if (b._visCount !== a._visCount) return b._visCount - a._visCount;
      return a.name.localeCompare(b.name);
    });

    return { funds, investors };
  }

  // -----------------------------------------------------------
  // Tooltip helpers
  // -----------------------------------------------------------
  const tooltip = document.getElementById('vis-tooltip');
  function showTooltip(html, evt) {
    tooltip.innerHTML = html;
    tooltip.style.display = 'block';
    moveTooltip(evt);
  }
  function moveTooltip(evt) {
    const wrap = document.querySelector('.vis-wrap').getBoundingClientRect();
    const x = Math.min(evt.clientX - wrap.left + 12, wrap.width - 300);
    const y = Math.min(evt.clientY - wrap.top + 12, wrap.height - 80);
    tooltip.style.left = x + 'px';
    tooltip.style.top = y + 'px';
  }
  function hideTooltip() { tooltip.style.display = 'none'; }

  // -----------------------------------------------------------
  // Matrix view
  // -----------------------------------------------------------
  function renderMatrix() {
    const { funds, investors } = computeFilteredLists();
    const svg = d3.select('#vis-svg');
    svg.selectAll('*').remove();

    if (funds.length === 0 || investors.length === 0) {
      svg.append('text')
        .attr('class', 'chord-empty-note')
        .attr('x', '50%').attr('y', '50%')
        .text('No data — relax a filter.');
      updateSelectionInfo(funds, investors);
      return;
    }

    const cellSize = 26;
    const rowLabelW = 260;
    const colLabelH = 180;
    const archetypeDotW = 16;
    const padLeft = 24, padTop = 24;

    const matrixW = funds.length * cellSize;
    const matrixH = investors.length * cellSize;
    const totalW = padLeft + rowLabelW + archetypeDotW + matrixW + 20;
    const totalH = padTop + colLabelH + matrixH + 30;

    svg.attr('viewBox', `0 0 ${totalW} ${totalH}`)
       .attr('preserveAspectRatio', 'xMinYMin meet')
       .style('min-width', totalW + 'px')
       .style('min-height', totalH + 'px');

    const matrixOriginX = padLeft + rowLabelW + archetypeDotW;
    const matrixOriginY = padTop + colLabelH;

    const fundIndex = new Map(funds.map((f, i) => [f.id, i]));
    const investorIndex = new Map(investors.map((inv, i) => [inv.id, i]));

    // INGO / non-INGO divider
    const firstNonIngoIdx = funds.findIndex(f => !f.ingo_backed);
    if (firstNonIngoIdx > 0 && firstNonIngoIdx < funds.length) {
      const x = matrixOriginX + firstNonIngoIdx * cellSize - 1;
      svg.append('line')
        .attr('class', 'matrix-section-divider')
        .attr('x1', x).attr('x2', x)
        .attr('y1', padTop + 4).attr('y2', matrixOriginY + matrixH);
    }

    // Column labels (rotated). Counts moved to tooltip — they fight with
    // the rotated names visually when stacked underneath.
    const colG = svg.append('g').attr('class', 'matrix-col-labels');
    funds.forEach((f, i) => {
      const x = matrixOriginX + i * cellSize + cellSize / 2;
      const y = matrixOriginY - 10;
      const g = colG.append('g')
        .attr('transform', `translate(${x},${y}) rotate(-50)`)
        .style('cursor', 'pointer')
        .on('mouseenter', evt => onColEnter(f, evt))
        .on('mouseleave', onColLeave)
        .on('mousemove', moveTooltip)
        .on('click', () => showDetailsForFund(f));
      g.append('text')
        .attr('class', 'matrix-col-label' + (f.ingo_backed ? '' : ' non-ingo'))
        .attr('data-fund-id', f.id)
        .attr('text-anchor', 'start')
        .attr('dy', '0.35em')
        .text(truncate(f.name, 30));
    });

    // Row labels and archetype dots
    const rowG = svg.append('g').attr('class', 'matrix-row-labels');
    investors.forEach((inv, i) => {
      const y = matrixOriginY + i * cellSize + cellSize / 2;
      const g = rowG.append('g')
        .style('cursor', 'pointer')
        .on('mouseenter', evt => onRowEnter(inv, evt))
        .on('mouseleave', onRowLeave)
        .on('mousemove', moveTooltip)
        .on('click', evt => onRowClick(inv, evt));

      g.append('rect')
        .attr('class', 'matrix-row-bg')
        .attr('data-investor-id', inv.id)
        .attr('x', padLeft)
        .attr('y', y - cellSize / 2)
        .attr('width', rowLabelW + archetypeDotW + matrixW)
        .attr('height', cellSize);

      g.append('text')
        .attr('class', 'matrix-row-label')
        .attr('data-investor-id', inv.id)
        .attr('x', padLeft + rowLabelW)
        .attr('y', y)
        .attr('dy', '0.35em')
        .text(truncate(inv.name, 32));

      g.append('circle')
        .attr('class', 'matrix-archetype-dot')
        .attr('cx', padLeft + rowLabelW + archetypeDotW / 2)
        .attr('cy', y)
        .attr('r', 4)
        .attr('fill', ARCHETYPE_COLOR[inv.archetype] || ARCHETYPE_COLOR.other);
    });

    // Subtle row banding — alternating hairline backgrounds so the eye
    // can track a row across 10+ columns of mostly-empty space.
    const bandG = svg.append('g').attr('class', 'matrix-bands');
    investors.forEach((inv, i) => {
      if (i % 2 === 1) return;
      bandG.append('rect')
        .attr('x', matrixOriginX)
        .attr('y', matrixOriginY + i * cellSize)
        .attr('width', matrixW)
        .attr('height', cellSize)
        .attr('fill', '#15171c');
    });

    // Cells. Empty cells are NOT drawn — the dark band IS the empty
    // state. Encoding:
    //   LP only:        filled rect, archetype colour
    //   Co-invest only: filled dot, archetype colour, sized by # portcos
    //   Both:           filled rect + small inner dot in bg colour
    const cellsG = svg.append('g').attr('class', 'matrix-cells');
    investors.forEach(inv => {
      const r = investorIndex.get(inv.id);
      const archColor = ARCHETYPE_COLOR[inv.archetype] || ARCHETYPE_COLOR.other;
      funds.forEach(f => {
        const c = fundIndex.get(f.id);
        const isLp = STATE.enabledRel.lp && inv.lp_funds.has(f.id);
        const coCount = STATE.enabledRel.coinvest ? (inv.coinvest_funds.get(f.id) || 0) : 0;
        if (!isLp && !coCount) return;

        const x = matrixOriginX + c * cellSize;
        const y = matrixOriginY + r * cellSize;

        const cell = cellsG.append('g')
          .attr('class', 'matrix-cell-group')
          .attr('data-fund-id', f.id)
          .attr('data-investor-id', inv.id)
          .style('cursor', 'pointer')
          .on('mouseenter', evt => onCellEnter(inv, f, isLp, coCount, evt))
          .on('mouseleave', onCellLeave)
          .on('mousemove', moveTooltip);

        if (isLp) {
          cell.append('rect')
            .attr('class', 'matrix-cell')
            .attr('x', x + 2).attr('y', y + 2)
            .attr('width', cellSize - 4).attr('height', cellSize - 4)
            .attr('rx', 3)
            .attr('fill', archColor);
          if (coCount) {
            cell.append('circle')
              .attr('class', 'matrix-cell-codot')
              .attr('cx', x + cellSize / 2)
              .attr('cy', y + cellSize / 2)
              .attr('r', 3)
              .attr('fill', '#0e0f12');
            if (coCount > 1) {
              cell.append('text')
                .attr('class', 'matrix-cell-conum')
                .attr('x', x + cellSize / 2)
                .attr('y', y + cellSize / 2)
                .attr('text-anchor', 'middle')
                .attr('dominant-baseline', 'central')
                .attr('font-size', '8px')
                .attr('font-weight', '700')
                .attr('fill', archColor)
                .text(coCount);
            }
          }
        } else {
          // Co-invest only: filled dot, sized by count (capped).
          const dotR = 4 + Math.min(coCount - 1, 4);
          cell.append('circle')
            .attr('class', 'matrix-cell-codot')
            .attr('cx', x + cellSize / 2)
            .attr('cy', y + cellSize / 2)
            .attr('r', dotR)
            .attr('fill', archColor);
          if (coCount > 1) {
            cell.append('text')
              .attr('class', 'matrix-cell-conum')
              .attr('x', x + cellSize / 2)
              .attr('y', y + cellSize / 2)
              .attr('text-anchor', 'middle')
              .attr('dominant-baseline', 'central')
              .attr('font-size', '9px')
              .attr('font-weight', '700')
              .attr('fill', '#0e0f12')
              .text(coCount);
          }
        }
      });
    });

    // INGO / non-INGO header label
    if (firstNonIngoIdx > 0) {
      svg.append('text')
        .attr('class', 'matrix-section-label')
        .attr('x', matrixOriginX)
        .attr('y', padTop)
        .text('INGO-Backed Funds');
      svg.append('text')
        .attr('class', 'matrix-section-label')
        .attr('x', matrixOriginX + firstNonIngoIdx * cellSize + 6)
        .attr('y', padTop)
        .text('Non-INGO-Backed Funds');
    }

    updateSelectionInfo(funds, investors);
  }

  function onRowEnter(inv, evt) {
    STATE.hot.investorId = inv.id;
    STATE.hot.fundId = null;
    applyHighlight();
    const lpNames = [...inv.lp_funds].map(id => DATA.funds.find(f => f.id === id)?.name).filter(Boolean);
    const coEntries = [...inv.coinvest_funds.entries()].map(([id, n]) => {
      const fname = DATA.funds.find(f => f.id === id)?.name;
      return fname ? `${fname} (${n} portco${n > 1 ? 's' : ''})` : null;
    }).filter(Boolean);
    let html = `<strong>${inv.name}</strong><br><span style="color:#888">${inv.archetype}</span><br>`;
    if (lpNames.length) html += `<br><b>LP in:</b><br>${lpNames.map(n => '· ' + n).join('<br>')}`;
    if (coEntries.length) html += `<br><br><b>Co-investor in:</b><br>${coEntries.map(n => '· ' + n).join('<br>')}`;
    showTooltip(html, evt);
  }
  function onRowLeave() {
    STATE.hot.investorId = null;
    applyHighlight();
    hideTooltip();
  }
  function onColEnter(fund, evt) {
    STATE.hot.fundId = fund.id;
    STATE.hot.investorId = null;
    applyHighlight();
    const html = `<strong>${fund.name}</strong><br><span style="color:#888">${fund.ingo_backed ? 'INGO-Backed Fund' : 'Non-INGO-Backed Fund'}</span><br><br>`
      + `<b>${fund.lp_count}</b> LP${fund.lp_count === 1 ? '' : 's'}<br>`
      + `<b>${fund.coinvest_count}</b> co-investor entit${fund.coinvest_count === 1 ? 'y' : 'ies'} (via portcos)`;
    showTooltip(html, evt);
  }
  function onColLeave() {
    STATE.hot.fundId = null;
    applyHighlight();
    hideTooltip();
  }
  function onCellEnter(inv, fund, isLp, coCount, evt) {
    STATE.hot.investorId = inv.id;
    STATE.hot.fundId = fund.id;
    applyHighlight();
    let html = `<strong>${inv.name}</strong> &times; <strong>${fund.name}</strong><br><br>`;
    if (isLp) html += `Direct LP commitment.<br>`;
    if (coCount) html += `Co-invested in <b>${coCount}</b> portco${coCount > 1 ? 's' : ''} of this fund.`;
    showTooltip(html, evt);
  }
  function onCellLeave() {
    STATE.hot.investorId = null;
    STATE.hot.fundId = null;
    applyHighlight();
    hideTooltip();
  }
  function onRowClick(inv, evt) {
    showDetailsForInvestor(inv);
  }

  function applyHighlight() {
    if (STATE.view !== 'matrix') return applyChordHighlight();

    const { investorId, fundId } = STATE.hot;
    const svg = d3.select('#vis-svg');

    // Row labels
    svg.selectAll('.matrix-row-label').each(function () {
      const el = d3.select(this);
      const id = el.attr('data-investor-id');
      el.classed('hot', id === investorId);
      el.classed('dim', !!investorId && id !== investorId);
    });
    svg.selectAll('.matrix-row-bg').each(function () {
      const el = d3.select(this);
      const id = el.attr('data-investor-id');
      el.classed('hot', id === investorId);
    });
    // Col labels
    svg.selectAll('.matrix-col-label').each(function () {
      const el = d3.select(this);
      const id = el.attr('data-fund-id');
      el.classed('hot', id === fundId);
      el.classed('dim', !!fundId && id !== fundId);
    });
    // Cells
    svg.selectAll('.matrix-cell-group').each(function () {
      const el = d3.select(this);
      const fId = el.attr('data-fund-id');
      const iId = el.attr('data-investor-id');
      let dim = false, hot = false;
      if (investorId && iId !== investorId) dim = true;
      if (fundId && fId !== fundId) dim = true;
      if (investorId && fundId && iId === investorId && fId === fundId) hot = true;
      else if (investorId && !fundId && iId === investorId) hot = true;
      else if (fundId && !investorId && fId === fundId) hot = true;
      el.classed('dim', dim).classed('hot', hot);
    });
  }

  function showDetailsForInvestor(inv) {
    const det = document.getElementById('node-details');
    const lpFunds = [...inv.lp_funds].map(id => DATA.funds.find(f => f.id === id)).filter(Boolean);
    const coEntries = [...inv.coinvest_funds.entries()].map(([id, n]) => ({
      fund: DATA.funds.find(f => f.id === id), n
    })).filter(x => x.fund);
    let html = `<h3>${inv.name}</h3><p class="muted">${inv.archetype}</p>`;
    html += `<p>Touches ${inv.total_count} fund${inv.total_count === 1 ? '' : 's'}.</p>`;
    if (lpFunds.length) {
      html += `<p><b>LP in:</b></p><ul>` + lpFunds.map(f => `<li>${f.name}</li>`).join('') + `</ul>`;
    }
    if (coEntries.length) {
      html += `<p><b>Co-investor in portcos of:</b></p><ul>`
        + coEntries.map(x => `<li>${x.fund.name} (${x.n} portco${x.n > 1 ? 's' : ''})</li>`).join('')
        + `</ul>`;
    }
    det.innerHTML = html;
    det.hidden = false;
  }

  function showDetailsForFund(fund) {
    const det = document.getElementById('node-details');
    const lps = DATA.investors.filter(inv => inv.lp_funds.has(fund.id));
    const cos = DATA.investors
      .filter(inv => inv.coinvest_funds.has(fund.id))
      .map(inv => ({ inv, n: inv.coinvest_funds.get(fund.id) }))
      .sort((a, b) => b.n - a.n);
    let html = `<h3>${fund.name}</h3><p class="muted">${fund.ingo_backed ? 'INGO-Backed Fund' : 'Non-INGO-Backed Fund'}</p>`;
    html += `<p>${fund.lp_count} LP${fund.lp_count === 1 ? '' : 's'}, `
          + `${fund.coinvest_count} co-investor entit${fund.coinvest_count === 1 ? 'y' : 'ies'}.</p>`;
    if (lps.length) {
      html += `<p><b>LPs:</b></p><ul>` + lps.map(i => `<li>${i.name} <span class="muted">(${i.archetype})</span></li>`).join('') + `</ul>`;
    }
    if (cos.length) {
      html += `<p><b>Co-investors (via portcos):</b></p><ul>`
        + cos.map(x => `<li>${x.inv.name} <span class="muted">(${x.inv.archetype}, ${x.n} portco${x.n > 1 ? 's' : ''})</span></li>`).join('')
        + `</ul>`;
    }
    det.innerHTML = html;
    det.hidden = false;
  }

  // -----------------------------------------------------------
  // Chord view — fund <-> fund arcs weighted by shared investors
  // -----------------------------------------------------------
  function renderChord() {
    let { funds, investors } = computeFilteredLists();
    const svg = d3.select('#vis-svg');
    svg.selectAll('*').remove();

    // Build N x N matrix where M[i][j] = count of investors that touch BOTH fund i and fund j
    // (for i != j), and M[i][i] = count touching only fund i (so the arc has a "self" weight too,
    // making the ring visible even for solo funds).
    if (funds.length === 0) {
      const w = document.querySelector('.vis-wrap').clientWidth;
      const h = document.querySelector('.vis-wrap').clientHeight;
      svg.attr('viewBox', `0 0 ${w} ${h}`);
      svg.append('text').attr('class', 'chord-empty-note').attr('x', w / 2).attr('y', h / 2)
        .text('No funds to chart — relax a filter.');
      updateSelectionInfo(funds, investors);
      return;
    }

    // First pass: compute cross-fund sharing only (no self-weights).
    // The chord chart's only job is to show overlap; single-fund
    // investors would inflate one arc into a ring-eating monster
    // (looking at you, Kiva with 43 single-touch investors).
    const fundIndex0 = new Map(funds.map((f, i) => [f.id, i]));
    const fullMatrix = Array.from({ length: funds.length }, () => Array(funds.length).fill(0));
    const fullShared = Array.from({ length: funds.length }, () =>
      Array.from({ length: funds.length }, () => []));

    investors.forEach(inv => {
      const visibleFunds = [];
      if (STATE.enabledRel.lp) {
        for (const fid of inv.lp_funds) if (fundIndex0.has(fid)) visibleFunds.push(fid);
      }
      if (STATE.enabledRel.coinvest) {
        for (const fid of inv.coinvest_funds.keys()) {
          if (fundIndex0.has(fid) && !visibleFunds.includes(fid)) visibleFunds.push(fid);
        }
      }
      if (visibleFunds.length < 2) return;
      for (let a = 0; a < visibleFunds.length; a++) {
        for (let b = a + 1; b < visibleFunds.length; b++) {
          const ia = fundIndex0.get(visibleFunds[a]);
          const ib = fundIndex0.get(visibleFunds[b]);
          fullMatrix[ia][ib] += 1;
          fullMatrix[ib][ia] += 1;
          fullShared[ia][ib].push(inv);
          fullShared[ib][ia].push(inv);
        }
      }
    });

    // Trim funds to those that participate in at least one cross-fund
    // edge — funds with zero shared investors don't belong on the ring.
    const participating = funds.filter((f, i) => fullMatrix[i].some(v => v > 0));

    const wrap = document.querySelector('.vis-wrap');
    const w = wrap.clientWidth || 900;
    const h = wrap.clientHeight || 600;
    svg.attr('viewBox', `0 0 ${w} ${h}`);

    if (participating.length < 2) {
      const g0 = svg.append('g').attr('transform', `translate(${w / 2},${h / 2})`);
      g0.append('text').attr('class', 'chord-empty-note').attr('y', -10)
        .text('No fund pairs share an investor yet.');
      g0.append('text').attr('class', 'chord-empty-note').attr('y', 14).style('font-size', '11px')
        .text('Switch to the Matrix tab — that view works on sparse data.');
      updateSelectionInfo(funds, investors);
      return;
    }

    // Rebuild the matrix on the trimmed fund set so D3 doesn't reserve
    // arc space for funds with zero ribbons.
    const N = participating.length;
    const fundIndex = new Map(participating.map((f, i) => [f.id, i]));
    const matrix = Array.from({ length: N }, () => Array(N).fill(0));
    const sharedDetails = Array.from({ length: N }, () =>
      Array.from({ length: N }, () => []));
    funds.forEach((fa, i0) => {
      const ia = fundIndex.get(fa.id);
      if (ia === undefined) return;
      funds.forEach((fb, j0) => {
        const ib = fundIndex.get(fb.id);
        if (ib === undefined) return;
        matrix[ia][ib] = fullMatrix[i0][j0];
        sharedDetails[ia][ib] = fullShared[i0][j0];
      });
    });

    const size = Math.min(w, h);
    const innerR = size * 0.28;
    const outerR = size * 0.33;
    const g = svg.append('g').attr('transform', `translate(${w / 2},${h / 2})`);

    const chord = d3.chord().padAngle(0.06).sortSubgroups(d3.descending);
    const chords = chord(matrix);

    // Re-bind the local `funds` variable used by the rest of the chord
    // renderer (label/arc/ribbon code) to the trimmed set. Naming kept
    // for legibility against the matrix code above.
    funds = participating;

    const colorScale = d3.scaleOrdinal()
      .domain(funds.map(f => f.id))
      .range(d3.quantize(d3.interpolateRainbow, Math.max(N, 6)));

    const arc = d3.arc().innerRadius(innerR).outerRadius(outerR);
    const ribbon = d3.ribbon().radius(innerR);

    // Arcs
    const arcG = g.append('g').attr('class', 'chord-arcs');
    chords.groups.forEach(grp => {
      const f = funds[grp.index];
      arcG.append('path')
        .attr('class', 'chord-arc')
        .attr('data-fund-id', f.id)
        .attr('d', arc(grp))
        .attr('fill', colorScale(f.id))
        .attr('opacity', f.ingo_backed ? 1 : 0.55)
        .on('mouseenter', evt => {
          STATE.hot.fundId = f.id;
          applyChordHighlight();
          const html = `<strong>${f.name}</strong><br><span style="color:#888">${f.ingo_backed ? 'INGO-Backed Fund' : 'Non-INGO-Backed Fund'}</span><br><br>`
            + `${f.lp_count} LP${f.lp_count === 1 ? '' : 's'}<br>`
            + `${f.coinvest_count} co-investor entit${f.coinvest_count === 1 ? 'y' : 'ies'}`;
          showTooltip(html, evt);
        })
        .on('mouseleave', () => { STATE.hot.fundId = null; applyChordHighlight(); hideTooltip(); })
        .on('mousemove', moveTooltip)
        .on('click', () => showDetailsForFund(f));
    });

    // Ribbons (cross-fund only — skip self-loops which are only there to bulk the ring)
    const ribbonG = g.append('g').attr('class', 'chord-ribbons');
    chords.forEach(c => {
      if (c.source.index === c.target.index) return;
      const i = c.source.index, j = c.target.index;
      const fA = funds[i], fB = funds[j];
      ribbonG.append('path')
        .attr('class', 'chord-ribbon')
        .attr('data-pair', `${fA.id}|${fB.id}`)
        .attr('d', ribbon(c))
        .attr('fill', colorScale(fA.id))
        .attr('stroke', d3.rgb(colorScale(fA.id)).darker())
        .on('mouseenter', evt => {
          STATE.hot.pair = `${fA.id}|${fB.id}`;
          applyChordHighlight();
          const shared = sharedDetails[i][j];
          let html = `<strong>${fA.name}</strong> ↔ <strong>${fB.name}</strong><br>`
            + `<span style="color:#888">${shared.length} shared investor${shared.length === 1 ? '' : 's'}</span><br><br>`
            + shared.map(inv => {
              const lpA = inv.lp_funds.has(fA.id), lpB = inv.lp_funds.has(fB.id);
              const coA = inv.coinvest_funds.get(fA.id) || 0, coB = inv.coinvest_funds.get(fB.id) || 0;
              const labelA = lpA ? 'LP' : `co-inv ${coA}`;
              const labelB = lpB ? 'LP' : `co-inv ${coB}`;
              return `· ${inv.name} <span style="color:#888">(${labelA} / ${labelB})</span>`;
            }).join('<br>');
          showTooltip(html, evt);
        })
        .on('mouseleave', () => { STATE.hot.pair = null; applyChordHighlight(); hideTooltip(); })
        .on('mousemove', moveTooltip);
    });

    // Labels — radial, flipped on the left half so they always read
    // left-to-right. A small tick line connects each label to its arc.
    const labelG = g.append('g').attr('class', 'chord-labels');
    chords.groups.forEach(grp => {
      const f = funds[grp.index];
      const angle = (grp.startAngle + grp.endAngle) / 2;
      const flip = angle > Math.PI;
      const labelR = outerR + 14;
      const tickEndR = outerR + 10;

      // Tick line
      labelG.append('line')
        .attr('x1', Math.sin(angle) * (outerR + 1))
        .attr('y1', -Math.cos(angle) * (outerR + 1))
        .attr('x2', Math.sin(angle) * tickEndR)
        .attr('y2', -Math.cos(angle) * tickEndR)
        .attr('stroke', '#444')
        .attr('stroke-width', 1);

      const lx = Math.sin(angle) * labelR;
      const ly = -Math.cos(angle) * labelR;
      const rotateDeg = (angle * 180 / Math.PI) - 90 + (flip ? 180 : 0);

      labelG.append('text')
        .attr('class', 'chord-label')
        .attr('data-fund-id', f.id)
        .attr('transform', `translate(${lx},${ly}) rotate(${rotateDeg})`)
        .attr('text-anchor', flip ? 'end' : 'start')
        .attr('dx', flip ? -4 : 4)
        .attr('dy', '0.35em')
        .style('cursor', 'pointer')
        .text(truncate(f.name, 28))
        .on('mouseenter', evt => {
          STATE.hot.fundId = f.id;
          applyChordHighlight();
        })
        .on('mouseleave', () => { STATE.hot.fundId = null; applyChordHighlight(); })
        .on('click', () => showDetailsForFund(f));
    });

    updateSelectionInfo(funds, investors);
  }

  // -----------------------------------------------------------
  // Sankey view — bridging investors between INGO and non-INGO funds.
  // 3 columns: INGO funds (left) → bridging investors (middle) → non-INGO funds (right).
  // Only investors that touch at least one fund on each side appear.
  // -----------------------------------------------------------
  function renderSankey() {
    const { funds, investors } = computeFilteredLists();
    const svg = d3.select('#vis-svg');
    svg.selectAll('*').remove();

    const wrap = document.querySelector('.vis-wrap');
    const w = wrap.clientWidth || 900;
    const h = wrap.clientHeight || 600;
    svg.attr('viewBox', `0 0 ${w} ${h}`);

    // Pull each investor's fund-ties (LP and/or co-invest, gated by
    // STATE.enabledRel) restricted to the currently-visible fund set.
    const fundIdSet = new Set(funds.map(f => f.id));
    const fundIngo = new Map(funds.map(f => [f.id, f.ingo_backed]));

    const bridges = [];
    investors.forEach(inv => {
      const touched = new Set();
      if (STATE.enabledRel.lp) {
        for (const fid of inv.lp_funds) if (fundIdSet.has(fid)) touched.add(fid);
      }
      if (STATE.enabledRel.coinvest) {
        for (const fid of inv.coinvest_funds.keys()) if (fundIdSet.has(fid)) touched.add(fid);
      }
      const ingoIds = [...touched].filter(id => fundIngo.get(id));
      const nonIngoIds = [...touched].filter(id => !fundIngo.get(id));
      if (ingoIds.length === 0 || nonIngoIds.length === 0) return;
      bridges.push({ investor: inv, ingoIds, nonIngoIds });
    });

    if (bridges.length === 0) {
      const g0 = svg.append('g').attr('transform', `translate(${w / 2},${h / 2})`);
      g0.append('text').attr('class', 'sankey-empty-note').attr('y', -10)
        .text('No investors yet bridge an INGO-Backed Fund and a Non-INGO-Backed Fund.');
      g0.append('text').attr('class', 'sankey-empty-note').attr('y', 14).style('font-size', '11px')
        .text('Adjust the relationship/archetype filters above, or check back as more funds get scraped.');
      updateSelectionInfo(funds, investors);
      return;
    }

    // Build sankey nodes/links. Three node kinds, prefixed so IDs don't
    // collide with the underlying fund IDs (a fund can only be on one side).
    const ingoFundIds = new Set();
    const nonIngoFundIds = new Set();
    bridges.forEach(b => {
      b.ingoIds.forEach(id => ingoFundIds.add(id));
      b.nonIngoIds.forEach(id => nonIngoFundIds.add(id));
    });

    const nodes = [];
    const nodeIndex = new Map();

    // INGO funds (col 0)
    [...ingoFundIds]
      .map(id => funds.find(f => f.id === id))
      .sort((a, b) => a.name.localeCompare(b.name))
      .forEach(f => {
        nodeIndex.set('I:' + f.id, nodes.length);
        nodes.push({ kind: 'ingo-fund', id: f.id, name: f.name, fund: f });
      });
    // Investors (col 1) — sorted by total connections desc.
    bridges
      .map(b => ({ inv: b.investor, score: b.ingoIds.length + b.nonIngoIds.length }))
      .sort((a, b) => b.score - a.score)
      .forEach(({ inv }) => {
        nodeIndex.set('V:' + inv.id, nodes.length);
        nodes.push({ kind: 'investor', id: inv.id, name: inv.name, archetype: inv.archetype });
      });
    // Non-INGO funds (col 2)
    [...nonIngoFundIds]
      .map(id => funds.find(f => f.id === id))
      .sort((a, b) => a.name.localeCompare(b.name))
      .forEach(f => {
        nodeIndex.set('N:' + f.id, nodes.length);
        nodes.push({ kind: 'non-ingo-fund', id: f.id, name: f.name, fund: f });
      });

    const links = [];
    bridges.forEach(b => {
      const invIdx = nodeIndex.get('V:' + b.investor.id);
      b.ingoIds.forEach(fid => {
        // Direction: INGO fund → investor (so capital "flows" left to right).
        links.push({
          source: nodeIndex.get('I:' + fid),
          target: invIdx,
          value: 1,
          investor: b.investor,
          fund: funds.find(f => f.id === fid),
          relKind: relationKindFor(b.investor, fid),
        });
      });
      b.nonIngoIds.forEach(fid => {
        links.push({
          source: invIdx,
          target: nodeIndex.get('N:' + fid),
          value: 1,
          investor: b.investor,
          fund: funds.find(f => f.id === fid),
          relKind: relationKindFor(b.investor, fid),
        });
      });
    });

    // Layout
    const sankey = d3.sankey()
      .nodeId(d => d.index)
      .nodeAlign(d3.sankeyJustify)
      .nodeWidth(18)
      .nodePadding(14)
      .extent([[160, 50], [w - 160, h - 30]]);

    sankey({ nodes, links });

    // Column headers
    const colsG = svg.append('g').attr('class', 'sankey-cols');
    const ingoNodes = nodes.filter(n => n.kind === 'ingo-fund');
    const invNodes = nodes.filter(n => n.kind === 'investor');
    const nonNodes = nodes.filter(n => n.kind === 'non-ingo-fund');
    const colCx = kind => {
      const arr = nodes.filter(n => n.kind === kind);
      if (!arr.length) return 0;
      return d3.mean(arr, n => (n.x0 + n.x1) / 2);
    };
    colsG.append('text').attr('class', 'sankey-col-label')
      .attr('x', colCx('ingo-fund')).attr('y', 30)
      .text(`INGO-Backed Funds (${ingoNodes.length})`);
    colsG.append('text').attr('class', 'sankey-col-label')
      .attr('x', colCx('investor')).attr('y', 30)
      .text(`Bridging investors (${invNodes.length})`);
    colsG.append('text').attr('class', 'sankey-col-label')
      .attr('x', colCx('non-ingo-fund')).attr('y', 30)
      .text(`Non-INGO-Backed Funds (${nonNodes.length})`);

    // Links
    const FUND_COLOR_INGO = '#3a8c3a';   // matches the brief's INGO swatch
    const FUND_COLOR_NON  = '#6c8aac';   // slate, distinct from INGO green
    function nodeFill(n) {
      if (n.kind === 'investor') return ARCHETYPE_COLOR[n.archetype] || ARCHETYPE_COLOR.other;
      return n.kind === 'ingo-fund' ? FUND_COLOR_INGO : FUND_COLOR_NON;
    }

    const linkG = svg.append('g').attr('class', 'sankey-links');
    links.forEach((l, i) => {
      const sNode = nodes[l.source.index ?? l.source];
      const path = linkG.append('path')
        .datum(l)
        .attr('class', 'sankey-link')
        .attr('data-link-idx', i)
        .attr('d', d3.sankeyLinkHorizontal()(l))
        .attr('stroke', nodeFill(l.investor ? { kind: 'investor', archetype: l.investor.archetype } : sNode))
        .attr('stroke-width', Math.max(1, l.width))
        .on('mouseenter', evt => {
          STATE.hot.linkIdx = i;
          applySankeyHighlight();
          const html = `<strong>${l.investor.name}</strong> &nbsp;${l.relKind}&nbsp; <strong>${l.fund.name}</strong>`
            + `<br><span style="color:#888">${l.fund.ingo_backed ? 'INGO-Backed Fund' : 'Non-INGO-Backed Fund'}</span>`;
          showTooltip(html, evt);
        })
        .on('mouseleave', () => { STATE.hot.linkIdx = null; applySankeyHighlight(); hideTooltip(); })
        .on('mousemove', moveTooltip);
    });

    // Nodes
    const nodeG = svg.append('g').attr('class', 'sankey-nodes');
    nodes.forEach((n, i) => {
      const g = nodeG.append('g')
        .datum(n)
        .attr('class', 'sankey-node')
        .attr('data-node-idx', i)
        .style('cursor', 'pointer')
        .on('mouseenter', evt => {
          STATE.hot.nodeIdx = i;
          applySankeyHighlight();
          let html = `<strong>${n.name}</strong>`;
          if (n.kind === 'investor') {
            html += `<br><span style="color:#888">${n.archetype}</span>`;
            const links_in  = links.filter(l => l.target.index === i);
            const links_out = links.filter(l => l.source.index === i);
            html += `<br><br>Bridges <b>${links_in.length}</b> INGO-Backed Fund(s) and <b>${links_out.length}</b> Non-INGO-Backed Fund(s).`;
          } else {
            html += `<br><span style="color:#888">${n.kind === 'ingo-fund' ? 'INGO-Backed Fund' : 'Non-INGO-Backed Fund'}</span>`;
            const myLinks = links.filter(l => l.source.index === i || l.target.index === i);
            html += `<br><br><b>${myLinks.length}</b> bridging investor connection(s).`;
          }
          showTooltip(html, evt);
        })
        .on('mouseleave', () => { STATE.hot.nodeIdx = null; applySankeyHighlight(); hideTooltip(); })
        .on('mousemove', moveTooltip)
        .on('click', () => {
          if (n.kind === 'investor') {
            const inv = DATA.investors.find(x => x.id === n.id);
            if (inv) showDetailsForInvestor(inv);
          } else {
            showDetailsForFund(n.fund);
          }
        });

      g.append('rect')
        .attr('x', n.x0).attr('y', n.y0)
        .attr('width', Math.max(1, n.x1 - n.x0))
        .attr('height', Math.max(1, n.y1 - n.y0))
        .attr('fill', nodeFill(n))
        .attr('rx', 2);

      // Labels: outside the column for the leftmost (right-aligned) and
      // rightmost (left-aligned) columns, inside-right for the middle.
      const labelOnLeft = n.kind === 'ingo-fund';
      const labelOnRight = n.kind === 'non-ingo-fund';
      const labelInside = n.kind === 'investor';

      const labelX = labelOnLeft ? n.x0 - 6
                  : labelOnRight ? n.x1 + 6
                  : n.x1 + 6;
      const anchor = labelOnLeft ? 'end' : 'start';

      g.append('text')
        .attr('x', labelX)
        .attr('y', (n.y0 + n.y1) / 2)
        .attr('dy', '0.35em')
        .attr('text-anchor', anchor)
        .text(truncate(n.name, 28));
    });

    updateSelectionInfo(funds, investors);
  }

  // Helper for sankey: which kind of relationship connects investor & fund?
  function relationKindFor(inv, fundId) {
    const isLp = inv.lp_funds.has(fundId);
    const co = inv.coinvest_funds.get(fundId) || 0;
    if (isLp && co) return `LP + co-invest (${co})`;
    if (isLp) return 'LP';
    if (co) return `co-invest (${co})`;
    return '?';
  }

  function applySankeyHighlight() {
    const { nodeIdx, linkIdx } = STATE.hot;
    const svg = d3.select('#vis-svg');

    // Read the bound `__data__` (set via .datum() at render time) so we
    // know which nodes/links to highlight without keeping a closure
    // reference to the full data arrays.
    svg.selectAll('.sankey-link').each(function () {
      const el = d3.select(this);
      const idx = +el.attr('data-link-idx');
      let hot = false, dim = false;
      if (linkIdx != null) {
        hot = (idx === linkIdx);
        dim = !hot;
      } else if (nodeIdx != null) {
        // Need to know whether this link touches nodeIdx.
        // d3-sankey leaves source/target as objects on the link datum; read via __data__.
        const d = el.node().__data__;
        if (d) {
          hot = (d.source.index === nodeIdx || d.target.index === nodeIdx);
          dim = !hot;
        }
      }
      el.classed('hot', hot).classed('dim', dim);
    });

    svg.selectAll('.sankey-node').each(function () {
      const el = d3.select(this);
      const idx = +el.attr('data-node-idx');
      let hot = false, dim = false;
      if (nodeIdx != null) {
        hot = (idx === nodeIdx);
        dim = !hot;
      } else if (linkIdx != null) {
        // Hot if it's an endpoint of the hot link.
        const link = svg.select(`.sankey-link[data-link-idx="${linkIdx}"]`).node();
        const d = link?.__data__;
        if (d) {
          hot = (d.source.index === idx || d.target.index === idx);
          dim = !hot;
        }
      }
      el.classed('hot', hot).classed('dim', dim);
    });
  }

  function applyChordHighlight() {
    const { fundId, pair } = STATE.hot;
    const svg = d3.select('#vis-svg');
    svg.selectAll('.chord-arc').each(function () {
      const el = d3.select(this);
      const id = el.attr('data-fund-id');
      el.classed('hot', id === fundId);
      el.classed('dim', !!fundId && id !== fundId);
    });
    svg.selectAll('.chord-label').each(function () {
      const el = d3.select(this);
      const id = el.attr('data-fund-id');
      el.classed('hot', id === fundId);
      el.classed('dim', !!fundId && id !== fundId);
    });
    svg.selectAll('.chord-ribbon').each(function () {
      const el = d3.select(this);
      const p = el.attr('data-pair');
      const [a, b] = p.split('|');
      let hot = false, dim = false;
      if (pair) { hot = (p === pair); dim = !hot; }
      else if (fundId) { hot = (a === fundId || b === fundId); dim = !hot; }
      el.classed('hot', hot).classed('dim', dim);
    });
  }

  // -----------------------------------------------------------
  // Selection-info banner
  // -----------------------------------------------------------
  function updateSelectionInfo(funds, investors) {
    const el = document.getElementById('selection-info');
    if (!funds.length || !investors.length) {
      el.textContent = 'No relationships visible — try relaxing a filter.';
      return;
    }
    const totalCells = investors.reduce((acc, inv) => acc + inv._visCount, 0);
    el.textContent = `${investors.length} investors × ${funds.length} funds · ${totalCells} relationships`
      + (STATE.search ? ` · search: "${STATE.search}"` : '');
  }

  // -----------------------------------------------------------
  // Render dispatcher + filter wiring
  // -----------------------------------------------------------
  function truncate(s, n) {
    if (!s) return '';
    return s.length > n ? s.slice(0, n - 1) + '…' : s;
  }

  function render() {
    document.getElementById('vis-loading')?.classList.remove('hidden');
    requestAnimationFrame(() => {
      try {
        if (STATE.view === 'matrix') renderMatrix();
        else if (STATE.view === 'chord') renderChord();
        else renderSankey();
      } finally {
        document.getElementById('vis-loading')?.classList.add('hidden');
      }
    });
  }

  // View tabs
  document.querySelectorAll('.view-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.view-tab').forEach(b => b.classList.toggle('active', b === btn));
      STATE.view = btn.dataset.view;
      // The "row filter" control only makes sense for the matrix.
      document.getElementById('ctrl-row-filter').style.display =
        STATE.view === 'matrix' ? '' : 'none';
      // Sankey is unfiltered by 'only-with-data' (always relevant) and
      // 'INGO-only' (which would empty the right column). Hint to the user.
      const ingoBox = document.getElementById('filter-ingo-only');
      const onlyDataBox = document.getElementById('filter-only-with-data');
      if (STATE.view === 'sankey') {
        if (ingoBox.checked) { ingoBox.checked = false; STATE.ingoOnly = false; }
      }
      render();
    });
  });

  // Investor type filters
  document.querySelectorAll('input[type="checkbox"][data-itype]').forEach(box => {
    box.addEventListener('change', () => {
      STATE.enabledTypes.clear();
      document.querySelectorAll('input[type="checkbox"][data-itype]').forEach(b => {
        if (b.checked) STATE.enabledTypes.add(b.dataset.itype);
      });
      render();
    });
  });

  // Relationship filters
  document.querySelectorAll('input[type="checkbox"][data-rel]').forEach(box => {
    box.addEventListener('change', () => {
      STATE.enabledRel.lp = document.querySelector('input[data-rel="lp"]').checked;
      STATE.enabledRel.coinvest = document.querySelector('input[data-rel="coinvest"]').checked;
      render();
    });
  });

  // INGO-only toggle
  document.getElementById('filter-ingo-only').addEventListener('change', e => {
    STATE.ingoOnly = e.target.checked;
    render();
  });
  // Only-with-data toggle
  document.getElementById('filter-only-with-data').addEventListener('change', e => {
    STATE.onlyWithData = e.target.checked;
    render();
  });

  // Search
  document.getElementById('filter-search').addEventListener('input', e => {
    STATE.search = e.target.value.trim();
    render();
  });

  // Row filter (matrix only)
  document.querySelectorAll('input[name="rowfilter"]').forEach(r => {
    r.addEventListener('change', () => {
      const v = document.querySelector('input[name="rowfilter"]:checked').value;
      STATE.rowFilter = v;
      render();
    });
  });

  // Click outside cells/rows to close details panel
  document.getElementById('vis-svg').addEventListener('click', e => {
    if (e.target.tagName === 'svg') {
      document.getElementById('node-details').hidden = true;
    }
  });

  // ---- Per-fund picker -----------------------------------------------
  // Populate the two checkbox lists once (funds don't change at runtime),
  // then wire up the change handlers and bulk shortcut buttons. The
  // existing "Only INGO-backed" master and "Only funds with investor data"
  // toggles still work; they layer on top of the per-fund set.
  function populateFundPickers() {
    const ingoList = document.getElementById('ctrl-fund-list-ingo');
    const nonList = document.getElementById('ctrl-fund-list-non');
    const ingoFunds = DATA.funds.filter(f => f.ingo_backed)
                                .sort((a, b) => a.name.localeCompare(b.name));
    const nonFunds = DATA.funds.filter(f => !f.ingo_backed)
                               .sort((a, b) => a.name.localeCompare(b.name));

    function row(f) {
      const wrap = document.createElement('label');
      if (f.total_count === 0) wrap.classList.add('empty-data');
      const cb = document.createElement('input');
      cb.type = 'checkbox';
      cb.dataset.fundId = f.id;
      cb.checked = STATE.enabledFunds.has(f.id);
      cb.addEventListener('change', () => {
        if (cb.checked) STATE.enabledFunds.add(f.id);
        else STATE.enabledFunds.delete(f.id);
        render();
      });
      wrap.appendChild(cb);
      wrap.appendChild(document.createTextNode(' ' + f.name + (f.total_count === 0 ? ' (no data)' : '')));
      return wrap;
    }

    ingoFunds.forEach(f => ingoList.appendChild(row(f)));
    nonFunds.forEach(f => nonList.appendChild(row(f)));

    document.getElementById('ctrl-fund-ingo-count').textContent =
      `${ingoFunds.length}`;
    document.getElementById('ctrl-fund-non-count').textContent =
      `${nonFunds.length}`;
  }
  populateFundPickers();

  document.querySelectorAll('button[data-fund-bulk]').forEach(btn => {
    btn.addEventListener('click', () => {
      const [grp, action] = btn.dataset.fundBulk.split(':');
      const targetIngo = grp === 'ingo';
      DATA.funds.filter(f => f.ingo_backed === targetIngo).forEach(f => {
        if (action === 'all') STATE.enabledFunds.add(f.id);
        else STATE.enabledFunds.delete(f.id);
      });
      // Sync checkbox UI.
      document.querySelectorAll('#ctrl-fund-list-ingo input, #ctrl-fund-list-non input').forEach(cb => {
        cb.checked = STATE.enabledFunds.has(cb.dataset.fundId);
      });
      render();
    });
  });

  // First render
  render();
</script>
