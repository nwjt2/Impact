---
layout: base.njk
title: DFI commitments
permalink: /dfis/index.html
pageKey: dfis
---

<section class="detail-page">
  <p class="back-link"><a href="{{ '/' | url }}">← Back to index</a></p>
  <header class="detail-header">
    <div class="detail-eyebrow">
      <span>Capital sources · development-finance institutions</span>
    </div>
    <h1>Development-finance institutions that fund INGO-GPs.</h1>
    <p class="detail-sub">{{ dfi_ingo_commits | length }} DFI profiles. Stated sector and geography preferences, emerging-manager facilities flagged where they exist, and disclosed INGO-GP commitments cross-linked to the peer-funds registry.</p>
  </header>

  <div class="filter-bar">
    <label class="filter-label" for="country-filter">DFI home country</label>
    <select id="country-filter" class="filter-select"></select>
    <span id="filter-summary" class="filter-summary"></span>
  </div>

  <div id="slot-2-list" class="dfi-list" aria-live="polite"></div>
  <div id="slot-2-empty" class="empty-state" hidden></div>
</section>

<script type="application/json" id="data-dfi-commits">{{ dfi_ingo_commits | dump | safe }}</script>
<script type="application/json" id="data-slot-meta">{{ slot_meta | dump | safe }}</script>

<script src="{{ '/assets/js/render.js' | url }}"></script>
<script>
(function () {
  "use strict";
  var I = window.IFC;
  var DFIS = I.loadJSON("data-dfi-commits") || [];
  var META = I.loadJSON("data-slot-meta") || {};

  var state = { country: "ALL" };

  function render() {
    var list = DFIS.filter(function (d) {
      return state.country === "ALL" || d.country === state.country;
    });
    list.sort(function (a, b) {
      var ac = (a.ingo_gp_commits || []).length, bc = (b.ingo_gp_commits || []).length;
      if (ac !== bc) return bc - ac;
      var ad = a.last_known_activity_date || "", bd = b.last_known_activity_date || "";
      if (ad && bd) return bd.localeCompare(ad);
      if (ad) return -1; if (bd) return 1;
      return (a.name || "").localeCompare(b.name || "");
    });

    var root = document.getElementById("slot-2-list");
    var empty = document.getElementById("slot-2-empty");
    var sum = document.getElementById("filter-summary");

    if (list.length === 0) {
      root.innerHTML = ""; empty.hidden = false;
      empty.innerHTML = "<p>No DFIs match <strong>" + I.esc(I.countryName(META, state.country)) + "</strong>. Try <em>All countries</em>.</p>";
      sum.textContent = "Showing 0 of " + DFIS.length;
      return;
    }
    empty.hidden = true; empty.innerHTML = "";
    root.innerHTML = list.map(function (d) { return I.renderDfiCard(d, META); }).join("");
    sum.textContent = "Showing " + list.length + " of " + DFIS.length;
  }

  document.getElementById("country-filter").innerHTML =
    I.buildCountryOptions(META, "slot_2_dfi_country").join("");
  document.getElementById("country-filter").addEventListener("change", function (e) {
    state.country = e.target.value; render();
  });

  I.installCardClick(".detail-page");
  render();
})();
</script>
