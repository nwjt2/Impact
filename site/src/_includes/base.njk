<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>IFC // {{ title or site.name }}</title>
  <meta name="robots" content="noindex" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="{{ '/assets/css/app.css' | url }}" />
</head>
<body class="{% if env.private %}private-build{% endif %}">
  <header class="site-header">
    <div class="masthead">
      <div class="masthead-brand">
        <span class="masthead-mark">IFC</span>
        <a class="masthead-title" href="{{ '/' | url }}">INGO First-Close Tool</a>
      </div>
      <nav class="site-nav">
        <a href="{{ '/' | url }}"{% if pageKey == 'index' %} aria-current="page"{% endif %}>Index</a>
        <a href="{{ '/network/' | url }}"{% if pageKey == 'network' %} aria-current="page"{% endif %}>Network</a>
        <a href="{{ '/catalysts/' | url }}"{% if pageKey == 'catalysts' %} aria-current="page"{% endif %}>Catalysts</a>
        <a href="{{ '/peer-funds/' | url }}"{% if pageKey == 'peer-funds' %} aria-current="page"{% endif %}>Peer funds</a>
        <a href="{{ '/impact-areas/' | url }}"{% if pageKey == 'impact-areas' %} aria-current="page"{% endif %}>Impact areas</a>
        <span class="nav-sep" aria-hidden="true">·</span>
        <a href="{{ '/dfis/' | url }}"{% if pageKey == 'dfis' %} aria-current="page"{% endif %}>DFIs</a>
        <a href="{{ '/foundations/' | url }}"{% if pageKey == 'foundations' %} aria-current="page"{% endif %}>Foundations</a>
        <a href="{{ '/family-offices/' | url }}"{% if pageKey == 'family-offices' %} aria-current="page"{% endif %}>Family offices</a>
        <a href="{{ '/asset-managers/' | url }}"{% if pageKey == 'asset-managers' %} aria-current="page"{% endif %}>Asset mgrs</a>
        <a href="{{ '/banks/' | url }}"{% if pageKey == 'banks' %} aria-current="page"{% endif %}>Banks</a>
        <a href="{{ '/pension-funds/' | url }}"{% if pageKey == 'pension-funds' %} aria-current="page"{% endif %}>Pensions</a>
        <a href="{{ '/corporates/' | url }}"{% if pageKey == 'corporates' %} aria-current="page"{% endif %}>Corporates</a>
        <a href="{{ '/government-donors/' | url }}"{% if pageKey == 'government-donors' %} aria-current="page"{% endif %}>Gov donors</a>
        <a href="{{ '/cooperative-ngos/' | url }}"{% if pageKey == 'cooperative-ngos' %} aria-current="page"{% endif %}>NGO/Coops</a>
      </nav>
      <div class="masthead-meta">
        {% if meta and meta.last_run_timestamp %}Last built {{ meta.last_run_timestamp | dateISO }}{% endif %}
      </div>
    </div>
  </header>

  <script>window.IFC_PATH_PREFIX = "{{ '/' | url }}";</script>

  <main class="site-main">
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <span>
      {% if meta %}Last built {{ meta.last_run_timestamp | dateISO }} · {{ slot_meta.slot_counts.peer_ingo_funds + slot_meta.slot_counts.dfi_ingo_commits + slot_meta.slot_counts.deadlines + slot_meta.slot_counts.foundation_lps + slot_meta.slot_counts.family_office_lps + slot_meta.slot_counts.bank_lps + slot_meta.slot_counts.asset_manager_lps + slot_meta.slot_counts.pension_fund_lps + slot_meta.slot_counts.corporate_lps + slot_meta.slot_counts.government_donor_lps + slot_meta.slot_counts.cooperative_ngo_lps }} records{% else %}Not yet run. Execute <code>make daily</code>.{% endif %}
    </span>
    <span>Public source links only · no telemetry</span>
  </footer>
</body>
</html>
