---
layout: base.njk
title: INGO First-Close Tool
pageKey: index
---

<section class="doc-title">
  <div class="doc-title-tag">
    <span>For INGO fund teams · pre-first-close</span>
    <span class="sep">·</span>
    <span>{{ slot_meta.slot_counts.deadlines }} deadlines · {{ slot_meta.slot_counts.dfi_ingo_commits }} DFIs · {{ slot_meta.slot_counts.foundation_lps }} foundations · {{ slot_meta.slot_counts.family_office_lps }} family offices · {{ slot_meta.slot_counts.peer_ingo_funds }} peer funds</span>
  </div>
  <h1 class="doc-title-h1">Every dated window, donor, and peer-fund close <span class="accent">— traced to a public source.</span></h1>
  <p class="doc-title-sub">Reference desk for INGO-sponsored impact funds. {{ slot_meta.slot_counts.deadlines }} dated items (application close-dates, regulator filings, board meetings, conferences), {{ slot_meta.slot_counts.dfi_ingo_commits }} DFI profiles, {{ slot_meta.slot_counts.foundation_lps }} foundation LPs, {{ slot_meta.slot_counts.family_office_lps }} family-office &amp; faith-based investors, {{ slot_meta.slot_counts.peer_ingo_funds }} peer first-close precedents. Each record carries a primary-source link and a last-verified timestamp. Local build, no telemetry.</p>
</section>

<section class="data-ribbon" id="data-ribbon"></section>

<section class="sec home-split">
  <div class="home-col home-col-impact">
    <header class="sec-head">
      <h2 class="sec-title">Impact areas <em>// DFIs active in the last 3 years AND with a current open call</em></h2>
      <a class="sec-link" href="{{ '/impact-areas/' | url }}">All sectors →</a>
    </header>
    <p class="ic-strapline muted">Sorted by combined count of <span class="cyan">active &amp; calling DFIs</span> and <span class="amber">peer-fund precedents</span>. A muted second bar shows <span class="violet">foundations &amp; family offices</span> that publicly name the sector as a stated priority — intent, not a confirmed check. Click a row for the underlying funds, DFIs &amp; LPs.</p>
    <div id="ic-home-chart" class="ic-chart-wrap"></div>
    <div id="ic-home-drawer" class="ic-drawer-wrap"></div>
  </div>

  <div class="home-col home-col-agenda">
    <header class="sec-head">
      <h2 class="sec-title">Upcoming deadlines <em>// fixed dates first</em></h2>
      <a class="sec-link" href="{{ '/deadlines/' | url }}">All {{ slot_meta.slot_counts.deadlines }} →</a>
    </header>
    <div id="agenda" class="agenda-paged"></div>
    <div id="agenda-pager" class="agenda-pager"></div>
    <div id="agenda-fns" class="agenda-fns"></div>
  </div>
</section>

<section class="sec">
  <header class="sec-head">
    <h2 class="sec-title">Capital sources <em>// LPs &amp; peer precedents</em></h2>
  </header>
  <div class="grid-2">
    <div id="shelf-dfis"></div>
    <div id="shelf-foundations"></div>
  </div>
  <div class="grid-2">
    <div id="shelf-famofs"></div>
    <div id="shelf-peers"></div>
  </div>
</section>

<aside class="footnotes">
  <div class="footnotes-head">
    <h3>About the data</h3>
    <span class="footnotes-meta">Last updated {{ meta.last_run_timestamp | dateISO }}</span>
  </div>
  <div class="footnotes-body">
    <p>Every entry links to a public disclosure — DFI press release, INGO annual report, regulator filing, or fund-manager website. Where a fact is not yet public, it is omitted; where a record cannot be re-verified, it is flagged <strong>UNVERIFIED</strong>. The site is static; no user data is collected, stored, or transmitted.</p>
  </div>
</aside>

<script type="application/json" id="data-peer-funds">{{ peer_ingo_funds | dump | safe }}</script>
<script type="application/json" id="data-dfi-commits">{{ dfi_ingo_commits | dump | safe }}</script>
<script type="application/json" id="data-deadlines">{{ deadlines | dump | safe }}</script>
<script type="application/json" id="data-foundations">{{ foundation_lps | dump | safe }}</script>
<script type="application/json" id="data-family-offices">{{ family_office_lps | dump | safe }}</script>
<script type="application/json" id="data-slot-meta">{{ slot_meta | dump | safe }}</script>
<script type="application/json" id="data-meta">{{ meta | dump | safe }}</script>
<script type="application/json" id="data-impact-areas">{{ impact_areas | dump | safe }}</script>

<script src="{{ '/assets/js/render.js' | url }}"></script>
<script>
(function () {
  "use strict";
  var I = window.IFC;

  var PEER   = I.loadJSON("data-peer-funds")     || [];
  var DFIS   = I.loadJSON("data-dfi-commits")    || [];
  var DEADS  = I.loadJSON("data-deadlines")      || [];
  var FDNS   = I.loadJSON("data-foundations")    || [];
  var FAMOFS = I.loadJSON("data-family-offices") || [];
  var META   = I.loadJSON("data-slot-meta")      || {};
  var BUILD  = I.loadJSON("data-meta")           || {};

  var TODAY = (BUILD.last_run_timestamp || BUILD.generated_at || new Date().toISOString()).slice(0, 10);

  function daysBetween(a, b) {
    return Math.round((Date.parse(b) - Date.parse(a)) / 86400000);
  }
  function pad(n) { return n < 10 ? "0" + n : "" + n; }

  // ---------- Data ribbon ----------
  function renderRibbon() {
    var horizonMs = Date.parse(TODAY) + 90 * 86400000;
    var horizon = new Date(horizonMs).toISOString().slice(0, 10);
    var nearDeadlines = DEADS.filter(function (d) {
      return d.deadline_date && d.deadline_date >= TODAY && d.deadline_date <= horizon;
    });
    var critical = nearDeadlines.filter(function (d) {
      return daysBetween(TODAY, d.deadline_date) <= 14;
    }).length;

    var commitCount = 0, distinctDfis = 0;
    DFIS.forEach(function (d) {
      var n = (d.ingo_gp_commits || []).length;
      if (n > 0) distinctDfis++;
      commitCount += n;
    });

    var sized = PEER.filter(function (f) { return f.size_usd_m != null; });
    var totalSized = sized.reduce(function (s, f) { return s + f.size_usd_m; }, 0);

    var totalRecords = DEADS.length + DFIS.length + PEER.length;

    function cell(label, num, tail) {
      return '<div class="data-cell">'
        + '<div class="data-cell-label">' + I.esc(label) + '</div>'
        + '<div class="data-cell-num">' + num + '</div>'
        + '<div class="data-cell-tail">' + tail + '</div>'
        + '</div>';
    }

    return [
      cell(
        "Deadlines, next 90 days",
        nearDeadlines.length,
        critical > 0
          ? '<strong class="warn">' + critical + '</strong> inside 14 days'
          : 'none inside 14 days'
      ),
      cell(
        "Disclosed DFI commits",
        commitCount,
        'across <strong>' + distinctDfis + ' of ' + DFIS.length + '</strong> DFIs'
      ),
      cell(
        "Peer fund AUM",
        '$' + Math.round(totalSized).toLocaleString() + 'M',
        'disclosed across <strong>' + sized.length + ' of ' + PEER.length + '</strong> funds'
      ),
      cell(
        "Last verified",
        I.fmtDate(TODAY),
        'all <strong>' + totalRecords + '</strong> records re-checked'
      ),
    ].join("");
  }

  // ---------- Agenda blotter ----------
  var KIND_LABELS = {
    rfp: "RFP", open_call: "Open call", rolling_application: "Rolling",
    board_meeting: "Board", template_revision: "Template",
    regulator_filing: "Reg filing", conference_deadline: "Conference",
  };

  var AGENDA_PAGE_SIZE = 8;
  var agendaPage = 0;

  function renderAgenda() {
    var sources = [];
    function srcNum(url) {
      if (!url) return "";
      var idx = sources.indexOf(url);
      if (idx === -1) { sources.push(url); idx = sources.length - 1; }
      return idx + 1;
    }

    var hard = DEADS.filter(function (d) {
      return d.deadline_date && d.deadline_date >= TODAY;
    }).sort(function (a, b) { return a.deadline_date.localeCompare(b.deadline_date); });

    if (hard.length === 0) {
      return {
        html: '<p class="muted" style="padding:18px 0;">No fixed-date deadlines coming up. See <a href="{{ "/deadlines/" | url }}">all {{ slot_meta.slot_counts.deadlines }} records</a> for rolling and recurring programs.</p>',
        sources: [], pageCount: 0,
      };
    }

    var pageCount = Math.ceil(hard.length / AGENDA_PAGE_SIZE);
    if (agendaPage >= pageCount) agendaPage = 0;
    var start = agendaPage * AGENDA_PAGE_SIZE;
    var page = hard.slice(start, start + AGENDA_PAGE_SIZE);

    var rows = page.map(function (d) {
      var days = daysBetween(TODAY, d.deadline_date);
      var rel = days === 0 ? "today"
        : days < 60 ? days + "d"
        : Math.round(days / 30) + "mo";
      var relCls = "dl-rel" + (days <= 7 ? " is-critical" : days <= 14 ? " is-imminent" : "");
      var dStr = I.fmtDate(d.deadline_date);
      var verb = I.dateVerb(d.kind);
      var dateCell = verb
        ? '<span class="dl-date-verb">' + I.esc(verb) + '</span> <span class="dl-date-value">' + dStr + '</span>'
        : dStr;
      var n = srcNum(d.public_source_url);

      return '<tr class="dl-kind-' + I.esc(d.kind) + (d.public_source_url ? ' card-clickable' : '') +
        '" data-source-url="' + I.escAttr(d.public_source_url || "") + '">'
        + '<td class="col-date">' + dateCell + '</td>'
        + '<td class="col-rel"><span class="' + relCls + '">' + rel + '</span></td>'
        + '<td><span class="dl-title">' + I.esc(d.title) + '</span>' + (n ? '<sup class="dl-source-num">' + n + '</sup>' : '') + '</td>'
        + '<td class="col-issuer">' + I.esc(d.issuing_body || "") + '</td>'
        + '<td class="col-kind"><span class="dl-kind"><span class="dl-kind-dot"></span>' + I.esc(KIND_LABELS[d.kind] || d.kind) + '</span></td>'
        + '</tr>';
    }).join("");

    return {
      html:
        '<table class="dl-table"><thead><tr>'
        + '<th class="col-date">When</th>'
        + '<th class="col-rel">In</th>'
        + '<th>Item</th>'
        + '<th class="col-issuer">From</th>'
        + '<th class="col-kind">Kind</th>'
        + '</tr></thead><tbody>' + rows + '</tbody></table>',
      sources: sources,
      pageCount: pageCount,
      total: hard.length,
      pageStart: start + 1,
      pageEnd: start + page.length,
    };
  }

  function renderAgendaPager(meta) {
    if (!meta || meta.pageCount <= 1) return "";
    var prevDis = agendaPage <= 0 ? " is-disabled" : "";
    var nextDis = agendaPage >= meta.pageCount - 1 ? " is-disabled" : "";
    return ''
      + '<button type="button" class="agenda-pg agenda-pg-prev' + prevDis + '" aria-label="Previous deadlines">‹ prev</button>'
      + '<span class="agenda-pg-status">'
        + meta.pageStart + '–' + meta.pageEnd + ' of ' + meta.total
      + '</span>'
      + '<button type="button" class="agenda-pg agenda-pg-next' + nextDis + '" aria-label="Next deadlines">next ›</button>';
  }

  function mountAgenda() {
    var ag = renderAgenda();
    document.getElementById("agenda").innerHTML = ag.html;
    document.getElementById("agenda-pager").innerHTML = renderAgendaPager(ag);
    document.getElementById("agenda-fns").innerHTML = renderFootnotes(ag.sources);
  }

  // ---------- Reference panels ----------
  function renderShelfDfis() {
    var ranked = DFIS.slice().sort(function (a, b) {
      var ac = (a.ingo_gp_commits || []).length;
      var bc = (b.ingo_gp_commits || []).length;
      if (ac !== bc) return bc - ac;
      var ad = a.last_known_activity_date || "";
      var bd = b.last_known_activity_date || "";
      return bd.localeCompare(ad);
    }).slice(0, 7);

    var rows = ranked.map(function (d, i) {
      var commits = (d.ingo_gp_commits || []).length;
      var emf = d.emerging_manager_facility && d.emerging_manager_facility.exists;
      var url = d.stated_thesis_url || d.public_newsroom_url || d.last_known_activity_url || '{{ "/dfis/" | url }}';
      return '<tr><td class="ref-rank">' + pad(i + 1) + '</td>'
        + '<td>'
        + '<div class="ref-name"><a href="' + I.escAttr(url) + '" target="_blank" rel="noopener">' + I.esc(d.name) + '</a></div>'
        + '<div class="ref-meta">' + I.esc(I.countryName(META, d.country))
          + (emf ? '<span class="emf">EMF facility</span>' : '')
          + '</div>'
        + '</td>'
        + '<td class="num"><span class="ref-figure">' + commits + '</span><span class="ref-figure-label">commits</span></td>'
        + '</tr>';
    }).join("");

    return '<div class="panel">'
      + '<div class="panel-head"><span class="label">DFIs by INGO-GP commitments</span><a class="tail" href="{{ "/dfis/" | url }}">All ' + DFIS.length + ' →</a></div>'
      + '<table class="ref-list"><tbody>' + rows + '</tbody></table>'
      + '</div>';
  }

  var FOUNDATION_TYPE_LABELS = {
    private: "Private", corporate: "Corporate", community: "Community",
    operating: "Operating", public_charity: "Public charity",
    supporting_org: "Supporting org", philanthropy: "Philanthropy LLC"
  };

  function renderShelfFoundations() {
    var ranked = FDNS.slice().sort(function (a, b) {
      var ac = (a.known_ingo_gp_commits || []).length;
      var bc = (b.known_ingo_gp_commits || []).length;
      if (ac !== bc) return bc - ac;
      return (a.name || "").localeCompare(b.name || "");
    }).slice(0, 7);

    var rows = ranked.map(function (d, i) {
      var commits = (d.known_ingo_gp_commits || []).length;
      var url = d.stated_thesis_url || d.public_newsroom_url || '{{ "/foundations/" | url }}';
      var typeLabel = FOUNDATION_TYPE_LABELS[d.foundation_type] || "";
      return '<tr><td class="ref-rank">' + pad(i + 1) + '</td>'
        + '<td>'
        + '<div class="ref-name"><a href="' + I.escAttr(url) + '" target="_blank" rel="noopener">' + I.esc(d.name) + '</a></div>'
        + '<div class="ref-meta">' + I.esc(I.countryName(META, d.country))
          + (typeLabel ? '<span class="emf">' + I.esc(typeLabel) + '</span>' : '')
          + '</div>'
        + '</td>'
        + '<td class="num"><span class="ref-figure">' + commits + '</span><span class="ref-figure-label">commits</span></td>'
        + '</tr>';
    }).join("");

    return '<div class="panel">'
      + '<div class="panel-head"><span class="label">Foundations &amp; corporate-impact arms</span><a class="tail" href="{{ "/foundations/" | url }}">All ' + FDNS.length + ' →</a></div>'
      + '<table class="ref-list"><tbody>' + rows + '</tbody></table>'
      + '</div>';
  }

  var FAMILY_OFFICE_CATEGORY_LABELS = {
    family_office: "Family office", faith_based: "Faith-based",
    daf: "DAF", philanthropy_llc: "Philanthropy LLC", hnwi_collective: "HNWI"
  };

  function renderShelfFamilyOffices() {
    var ranked = FAMOFS.slice().sort(function (a, b) {
      var ac = (a.known_ingo_gp_commits || []).length;
      var bc = (b.known_ingo_gp_commits || []).length;
      if (ac !== bc) return bc - ac;
      return (a.name || "").localeCompare(b.name || "");
    }).slice(0, 7);

    var rows = ranked.map(function (d, i) {
      var commits = (d.known_ingo_gp_commits || []).length;
      var url = d.stated_thesis_url || d.public_newsroom_url || '{{ "/family-offices/" | url }}';
      var catLabel = FAMILY_OFFICE_CATEGORY_LABELS[d.category] || "";
      return '<tr><td class="ref-rank">' + pad(i + 1) + '</td>'
        + '<td>'
        + '<div class="ref-name"><a href="' + I.escAttr(url) + '" target="_blank" rel="noopener">' + I.esc(d.name) + '</a></div>'
        + '<div class="ref-meta">' + I.esc(I.countryName(META, d.country))
          + (catLabel ? '<span class="emf">' + I.esc(catLabel) + '</span>' : '')
          + '</div>'
        + '</td>'
        + '<td class="num"><span class="ref-figure">' + commits + '</span><span class="ref-figure-label">commits</span></td>'
        + '</tr>';
    }).join("");

    return '<div class="panel">'
      + '<div class="panel-head"><span class="label">Family offices, faith-based &amp; philanthropy LLCs</span><a class="tail" href="{{ "/family-offices/" | url }}">All ' + FAMOFS.length + ' →</a></div>'
      + '<table class="ref-list"><tbody>' + rows + '</tbody></table>'
      + '</div>';
  }

  function renderShelfPeers() {
    var ranked = PEER.slice().sort(function (a, b) {
      var ad = a.first_close_date || "0000";
      var bd = b.first_close_date || "0000";
      if (ad !== bd) return bd.localeCompare(ad);
      return (b.size_usd_m || 0) - (a.size_usd_m || 0);
    }).slice(0, 7);

    var rows = ranked.map(function (f, i) {
      var url = f.public_source_url || ('{{ "/peer-funds/" | url }}#fund-' + f.slug);
      var size = f.size_usd_m != null ? "$" + f.size_usd_m + "M" : "n/d";
      var dateStr = f.first_close_date ? f.first_close_date.slice(0, 7) : (f.vintage ? String(f.vintage) : "—");
      return '<tr><td class="ref-rank">' + pad(i + 1) + '</td>'
        + '<td>'
        + '<div class="ref-name"><a href="' + I.escAttr(url) + '" target="_blank" rel="noopener">' + I.esc(f.name) + '</a></div>'
        + '<div class="ref-meta">' + I.esc(f.parent_ingo) + ' · ' + I.esc(I.countryName(META, f.parent_ingo_country)) + '</div>'
        + '</td>'
        + '<td class="num"><span class="ref-figure">' + size + '</span><span class="ref-figure-label">' + dateStr + '</span></td>'
        + '</tr>';
    }).join("");

    return '<div class="panel">'
      + '<div class="panel-head"><span class="label">Peer funds by first-close recency</span><a class="tail" href="{{ "/peer-funds/" | url }}">All ' + PEER.length + ' →</a></div>'
      + '<table class="ref-list"><tbody>' + rows + '</tbody></table>'
      + '</div>';
  }

  function renderFootnotes(sources) {
    if (!sources || sources.length === 0) return "";
    return sources.map(function (url, i) {
      var host = "";
      try { host = new URL(url).host.replace(/^www\./, ""); } catch (e) { host = url; }
      return '<span><span class="fn-num">' + (i + 1) + '</span><a href="' + I.escAttr(url) + '" target="_blank" rel="noopener">' + I.esc(host) + '</a></span>';
    }).join("");
  }

  // ---------- Mount ----------
  document.getElementById("data-ribbon").innerHTML = renderRibbon();
  mountAgenda();
  document.getElementById("shelf-dfis").innerHTML        = renderShelfDfis();
  document.getElementById("shelf-foundations").innerHTML = renderShelfFoundations();
  document.getElementById("shelf-famofs").innerHTML      = renderShelfFamilyOffices();
  document.getElementById("shelf-peers").innerHTML       = renderShelfPeers();

  // Impact-areas chart — homepage variant: 3y "active DFI" filter is locked on.
  var IMPACT = I.loadJSON("data-impact-areas") || [];
  var icChart  = document.getElementById("ic-home-chart");
  var icDrawer = document.getElementById("ic-home-drawer");
  if (icChart && IMPACT.length > 0) {
    I.renderImpactChart(icChart, icDrawer, IMPACT, { useActive: true, useCalling: true, openFirst: false });
  }

  // Whole-row click on agenda (delegated)
  var agendaEl = document.getElementById("agenda");
  agendaEl.addEventListener("click", function (evt) {
    if (evt.target.closest("a")) return;
    var row = evt.target.closest("tr.card-clickable");
    if (!row) return;
    var url = row.getAttribute("data-source-url");
    if (url) window.open(url, "_blank", "noopener,noreferrer");
  });

  // Agenda pagination
  document.getElementById("agenda-pager").addEventListener("click", function (evt) {
    var btn = evt.target.closest(".agenda-pg");
    if (!btn || btn.classList.contains("is-disabled")) return;
    if (btn.classList.contains("agenda-pg-prev")) agendaPage = Math.max(0, agendaPage - 1);
    if (btn.classList.contains("agenda-pg-next")) agendaPage = agendaPage + 1;
    mountAgenda();
  });
})();
</script>
