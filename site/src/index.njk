---
layout: base.njk
title: INGO First-Close Tool
pageKey: index
---

<section class="doc-title">
  <div class="doc-title-tag">
    <span>For INGO fund teams · pre-first-close</span>
  </div>
  <h1 class="doc-title-h1">Dated windows, donors, and peer-fund closes <span class="accent">— traced to a public source where one is published.</span></h1>
  <p class="doc-title-sub">Reference desk for INGO-sponsored impact funds, covering deadlines, capital sources, and peer first-close precedents. Most records link back to a primary source. Peer-fund entries that can't be re-verified are flagged <strong>UNVERIFIED</strong>; for DFI / foundation / family-office entries, the data ribbon below counts records with no source URL on file. UNVERIFIED is a peer-funds-only flag.</p>
</section>

<section class="data-ribbon" id="data-ribbon"></section>

<section class="sec home-split home-split-network">
  <div class="home-col home-col-network">
    <header class="sec-head">
      <h2 class="sec-title">Capital sources behind peer impact funds <em>// already wrote a check</em></h2>
      <a class="sec-link" href="{{ '/network/' | url }}">Map of all {{ network.stats.edge_count }} ties →</a>
    </header>
    <p class="lp-headline">
      <strong class="lp-headline-num">{{ home_summary.lpDistinctCount }}</strong>
      <span class="lp-headline-tail">named investors have already LP'd into a peer impact fund — public-source confirmed.</span>
    </p>
    <p class="lp-headline-split muted">
      <strong>{{ home_summary.lpInvestorIngoCount }}</strong> have backed an INGO-sponsored vehicle so far · <strong>{{ home_summary.lpInvestorComparableOnlyCount }}</strong> are documented only on non-INGO comparables (still relevant prospects, but not yet on record as INGO-fund LPs).
    </p>
    <p class="lp-callouts">
      Includes
      {% for f in home_summary.lpFeatured %}<span class="lp-callout-name" data-arch="{{ f.archetype }}">{{ f.name }}</span>{% if not loop.last %} · {% endif %}{% endfor %}
      <span class="muted">— and {{ home_summary.lpDistinctCount - (home_summary.lpFeatured | length) }} more.</span>
    </p>
    <div class="lp-wall" aria-label="All known LPs into peer impact funds, colored by archetype">
      {% for l in home_summary.lpWall %}<span class="lp-chip" data-arch="{{ l.archetype }}" data-count="{{ l.count }}" style="--c: {{ l.count }}" title="{{ l.name }} — {{ l.count }} peer impact fund{% if l.count != 1 %}s{% endif %}{% for f in l.funds %}
· {{ f.name }}{% if f.source_url %} (src: {{ f.source_url | sourceHost }}){% endif %}{% endfor %}"></span>{% endfor %}
    </div>
    <ul class="lp-legend">
      {% for r in home_summary.lpArchetypeRollup %}<li><span class="lp-legend-dot" data-arch="{{ r.archetype }}"></span> {{ r.archetype | replace('-', ' ') }} <span class="muted">{{ r.count }}</span></li>{% endfor %}
    </ul>
    <p class="lp-coverage muted">Drawn from {{ home_summary.lpFundsCoveredCount }} of the {{ home_summary.lpFundsTotal }} funds in the graph with disclosed LP rolls — {{ home_summary.lpFundsCoveredIngo }} INGO-backed plus {{ home_summary.lpFundsCoveredComparable }} comparables.</p>
  </div>

  <div class="home-col home-col-catalysts">
    <header class="sec-head">
      <h2 class="sec-title">Catalysts <em>// portcos that drew non-INGO capital</em></h2>
      <a class="sec-link" href="{{ '/catalysts/' | url }}">All {{ network.stats.catalyst_count }} →</a>
    </header>
    <p class="cat-mini-headline muted">
      Portfolio companies of INGO-Backed Funds that have attracted capital from <em>outside</em>
      the INGO ecosystem. Templates for where to invest next if catalysing third-party capital is the goal.
    </p>
    <ol class="cat-mini-list">
      {% for c in home_summary.topCatalysts %}
        <li class="cat-mini-card">
          <span class="cat-mini-rank top">{{ loop.index }}</span>
          <div class="cat-mini-body">
            <div class="cat-mini-name">
              {% if c.website %}<a href="{{ c.website }}" target="_blank" rel="noopener">{{ c.name }}</a>{% else %}{{ c.name }}{% endif %}
            </div>
            <div class="cat-mini-meta">
              {% if c.country %}{{ c.country }} · {% endif %}via {% for f in c.ingo_funds %}{{ f.name }}{% if not loop.last %}, {% endif %}{% endfor %}
            </div>
            {% if c.archetype_counts | length > 0 %}
              <div class="cat-mini-archroll">
                {% for ac in c.archetype_counts %}<span class="cat-mini-archdot" data-arch="{{ ac.archetype }}" title="{{ ac.archetype }}: {{ ac.count }}"></span><span class="cat-mini-archcount">{{ ac.count }}</span>{% endfor %}
              </div>
            {% endif %}
          </div>
          <div class="cat-mini-summary">
            <span class="cat-mini-bigcount">{{ c.non_ingo_total }}</span>
            <span class="cat-mini-bigcount-lbl">non-INGO funders</span>
          </div>
        </li>
      {% endfor %}
    </ol>
    <p class="cat-mini-coverage muted">
      Coverage: {{ network.stats.catalyst_count }} of {{ network.stats.ingo_backed_portco_count }} INGO-fund portcos have a known non-INGO funder so far. The empty bottom is an absence of scraped co-investor data, not an absence of catalysis.
    </p>
  </div>
</section>

<section class="sec home-split">
  <div class="home-col home-col-impact">
    <header class="sec-head">
      <h2 class="sec-title">Impact areas <em>// DFIs active in the last 3 years AND with a current open call</em></h2>
      <a class="sec-link" href="{{ '/impact-areas/' | url }}">All sectors →</a>
    </header>
    <p class="ic-strapline muted">Capital sources on the left, fund vehicles on the right. Sorted by combined count of <span class="cyan">active &amp; calling DFIs</span> and <span class="amber">peer-fund precedents</span>; a muted second bar shows <span class="violet">foundations &amp; family offices</span> that name the sector as a stated priority — intent, not a confirmed check. Click a row for the underlying LPs &amp; funds.</p>
    <div id="ic-home-chart" class="ic-chart-wrap"></div>
    <div id="ic-home-drawer" class="ic-drawer-wrap"></div>
  </div>

  <div class="home-col home-col-agenda">
    <header class="sec-head">
      <h2 class="sec-title">Upcoming deadlines <em>// fixed dates first</em></h2>
      <a class="sec-link" href="{{ '/deadlines/' | url }}">All {{ slot_meta.slot_counts.deadlines }} →</a>
    </header>
    <div id="agenda" class="agenda-paged"></div>
    <div id="agenda-pager" class="agenda-pager"></div>
    <div id="agenda-fns" class="agenda-fns"></div>
  </div>
</section>

<section class="sec">
  <header class="sec-head">
    <h2 class="sec-title">Capital sources <em>// LPs &amp; peer precedents</em></h2>
  </header>
  <div class="grid-2">
    <div id="shelf-dfis"></div>
    <div id="shelf-foundations"></div>
  </div>
  <div class="grid-2">
    <div id="shelf-famofs"></div>
    <div id="shelf-peers"></div>
  </div>
</section>

<aside class="footnotes">
  <div class="footnotes-head">
    <h3>About the data</h3>
    <span class="footnotes-meta">Last updated {{ meta.last_run_timestamp | dateISO }}</span>
  </div>
  <div class="footnotes-body">
    <p>Most entries link to a public disclosure — DFI press release, INGO annual report, regulator filing, or fund-manager website. Peer-fund entries that can't be re-verified are flagged <strong>UNVERIFIED</strong> (some still carry an original source URL but haven't been re-checked). For DFI / foundation / family-office entries, the data ribbon counts records with no source URL on file. Where commitments exist but aren't yet public, they're omitted. The site is static; no user data is collected, stored, or transmitted.</p>
  </div>
</aside>

<script type="application/json" id="data-peer-funds">{{ peer_ingo_funds | dump | safe }}</script>
<script type="application/json" id="data-dfi-commits">{{ dfi_ingo_commits | dump | safe }}</script>
<script type="application/json" id="data-deadlines">{{ deadlines | dump | safe }}</script>
<script type="application/json" id="data-foundations">{{ foundation_lps | dump | safe }}</script>
<script type="application/json" id="data-family-offices">{{ family_office_lps | dump | safe }}</script>
<script type="application/json" id="data-slot-meta">{{ slot_meta | dump | safe }}</script>
<script type="application/json" id="data-meta">{{ meta | dump | safe }}</script>
<script type="application/json" id="data-impact-areas">{{ impact_areas | dump | safe }}</script>
<script type="application/json" id="data-network-lp-counts">{{ home_summary.networkLpCountBySlug | dump | safe }}</script>

<script src="{{ '/assets/js/render.js' | url }}"></script>
<script>
(function () {
  "use strict";
  var I = window.IFC;

  var PEER   = I.loadJSON("data-peer-funds")     || [];
  var DFIS   = I.loadJSON("data-dfi-commits")    || [];
  var DEADS  = I.loadJSON("data-deadlines")      || [];
  var FDNS   = I.loadJSON("data-foundations")    || [];
  var FAMOFS = I.loadJSON("data-family-offices") || [];
  var META   = I.loadJSON("data-slot-meta")      || {};
  var BUILD  = I.loadJSON("data-meta")           || {};
  var NET_LP = I.loadJSON("data-network-lp-counts") || {};

  var TODAY = (BUILD.last_run_timestamp || BUILD.generated_at || new Date().toISOString()).slice(0, 10);

  function daysBetween(a, b) {
    return Math.round((Date.parse(b) - Date.parse(a)) / 86400000);
  }
  function pad(n) { return n < 10 ? "0" + n : "" + n; }

  // ---------- Data ribbon ----------
  function renderRibbon() {
    var horizonMs = Date.parse(TODAY) + 90 * 86400000;
    var horizon = new Date(horizonMs).toISOString().slice(0, 10);
    var nearDeadlines = DEADS.filter(function (d) {
      return d.deadline_date && d.deadline_date >= TODAY && d.deadline_date <= horizon;
    });
    var critical = nearDeadlines.filter(function (d) {
      return daysBetween(TODAY, d.deadline_date) <= 14;
    }).length;

    var commitCount = 0, distinctDfis = 0;
    DFIS.forEach(function (d) {
      var n = (d.ingo_gp_commits || []).length;
      if (n > 0) distinctDfis++;
      commitCount += n;
    });

    // Peer-fund AUM split: verified records carry size figures we can stand
    // behind; unverified records still have disclosed sizes from their public
    // source but have not been re-verified, so we split the total.
    var sizedVer = 0, sizedUnv = 0, sizedVerCount = 0, sizedUnvCount = 0;
    PEER.forEach(function (f) {
      if (f.size_usd_m == null) return;
      if (f.validation_status === "unverified") { sizedUnv += f.size_usd_m; sizedUnvCount++; }
      else { sizedVer += f.size_usd_m; sizedVerCount++; }
    });

    // "Confirmed" = a record has a public source URL, or (for peer funds) is
    // explicitly flagged validation_status: verified. Foundations and family
    // offices are included because they're rendered on this page too.
    function hasUrl(d, fields) {
      for (var i = 0; i < fields.length; i++) if (d[fields[i]]) return true;
      return false;
    }
    var dfiUnv  = DFIS.filter(function (d) { return !hasUrl(d, ["stated_thesis_url", "public_newsroom_url", "last_known_activity_url"]); }).length;
    var fdnUnv  = FDNS.filter(function (d) { return !hasUrl(d, ["stated_thesis_url", "public_newsroom_url"]); }).length;
    var famUnv  = FAMOFS.filter(function (d) { return !hasUrl(d, ["stated_thesis_url", "public_newsroom_url"]); }).length;
    var peerUnv = PEER.filter(function (f) { return f.validation_status === "unverified"; }).length;
    var totalRecords = DEADS.length + DFIS.length + PEER.length + FDNS.length + FAMOFS.length;
    var totalUnv = dfiUnv + fdnUnv + famUnv + peerUnv;

    function cell(label, num, tail) {
      return '<div class="data-cell">'
        + '<div class="data-cell-label">' + I.esc(label) + '</div>'
        + '<div class="data-cell-num">' + num + '</div>'
        + '<div class="data-cell-tail">' + tail + '</div>'
        + '</div>';
    }

    return [
      cell(
        "Deadlines, next 90 days",
        nearDeadlines.length,
        critical > 0
          ? '<strong class="warn">' + critical + '</strong> inside 14 days'
          : 'none inside 14 days'
      ),
      cell(
        "Disclosed DFI commits",
        commitCount,
        'across <strong>' + distinctDfis + ' of ' + DFIS.length + '</strong> DFIs'
      ),
      cell(
        "Peer fund AUM",
        '$' + Math.round(sizedVer).toLocaleString() + 'M',
        'verified · <strong class="warn">$' + Math.round(sizedUnv).toLocaleString() + 'M</strong> unverified'
          + '<br>across ' + (sizedVerCount + sizedUnvCount) + ' of ' + PEER.length + ' funds'
      ),
      cell(
        "Public sourcing",
        '<strong>' + (totalRecords - totalUnv) + '</strong>/' + totalRecords,
        'sourced &amp; verified · <strong class="warn">' + totalUnv
          + '</strong> flagged or no source URL'
          + '<br><span class="muted">peer-funds use UNVERIFIED flag; others use URL presence</span>'
      ),
    ].join("");
  }

  // ---------- Agenda blotter ----------
  var KIND_LABELS = {
    rfp: "RFP", open_call: "Open call", rolling_application: "Rolling",
    board_meeting: "Board", template_revision: "Template",
    regulator_filing: "Reg filing", conference_deadline: "Conference",
  };

  var AGENDA_PAGE_SIZE = 8;
  var agendaPage = 0;

  function renderAgenda() {
    var sources = [];
    function srcNum(url) {
      if (!url) return "";
      var idx = sources.indexOf(url);
      if (idx === -1) { sources.push(url); idx = sources.length - 1; }
      return idx + 1;
    }

    var hard = DEADS.filter(function (d) {
      return d.deadline_date && d.deadline_date >= TODAY;
    }).sort(function (a, b) { return a.deadline_date.localeCompare(b.deadline_date); });

    var rolling = DEADS.filter(function (d) {
      if (d.deadline_date) return false;
      if (d.recurring === "one_off" && !d.next_occurrence) return false;
      return true;
    }).sort(function (a, b) {
      var ar = a.recurring || "zzz", br = b.recurring || "zzz";
      if (ar !== br) return ar.localeCompare(br);
      return (a.title || "").localeCompare(b.title || "");
    });

    var items = hard.concat(rolling);

    if (items.length === 0) {
      return {
        html: '<p class="muted" style="padding:18px 0;">No deadlines on file. See <a href="{{ "/deadlines/" | url }}">all {{ slot_meta.slot_counts.deadlines }} records</a>.</p>',
        sources: [], pageCount: 0,
      };
    }

    var pageCount = Math.ceil(items.length / AGENDA_PAGE_SIZE);
    if (agendaPage >= pageCount) agendaPage = 0;
    var start = agendaPage * AGENDA_PAGE_SIZE;
    var page = items.slice(start, start + AGENDA_PAGE_SIZE);

    var rows = page.map(function (d) {
      var n = srcNum(d.public_source_url);
      var dateCell, relCell;
      if (d.deadline_date) {
        var days = daysBetween(TODAY, d.deadline_date);
        var rel = days === 0 ? "today"
          : days < 60 ? days + "d"
          : Math.round(days / 30) + "mo";
        var relCls = "dl-rel" + (days <= 7 ? " is-critical" : days <= 14 ? " is-imminent" : "");
        var dStr = I.fmtDate(d.deadline_date);
        var verb = I.dateVerb(d.kind);
        dateCell = verb
          ? '<span class="dl-date-verb">' + I.esc(verb) + '</span> <span class="dl-date-value">' + dStr + '</span>'
          : dStr;
        relCell = '<span class="' + relCls + '">' + rel + '</span>';
      } else {
        dateCell = '<span class="dl-date-rolling">' + I.esc(I.deadlineStatus(d)) + '</span>';
        relCell = '<span class="dl-rel-empty">—</span>';
      }

      return '<tr class="dl-kind-' + I.esc(d.kind) + (d.public_source_url ? ' card-clickable' : '') +
        '" data-source-url="' + I.escAttr(d.public_source_url || "") + '">'
        + '<td class="col-date">' + dateCell + '</td>'
        + '<td class="col-rel">' + relCell + '</td>'
        + '<td><span class="dl-title">' + I.esc(d.title) + '</span>' + (n ? '<sup class="dl-source-num">' + n + '</sup>' : '') + '</td>'
        + '<td class="col-issuer">' + I.esc(d.issuing_body || "") + '</td>'
        + '<td class="col-kind"><span class="dl-kind"><span class="dl-kind-dot"></span>' + I.esc(KIND_LABELS[d.kind] || d.kind) + '</span></td>'
        + '</tr>';
    }).join("");

    return {
      html:
        '<table class="dl-table"><thead><tr>'
        + '<th class="col-date">When</th>'
        + '<th class="col-rel">In</th>'
        + '<th>Item</th>'
        + '<th class="col-issuer">From</th>'
        + '<th class="col-kind">Kind</th>'
        + '</tr></thead><tbody>' + rows + '</tbody></table>',
      sources: sources,
      pageCount: pageCount,
      total: items.length,
      pageStart: start + 1,
      pageEnd: start + page.length,
    };
  }

  function renderAgendaPager(meta) {
    if (!meta || meta.pageCount <= 1) return "";
    var prevDis = agendaPage <= 0 ? " is-disabled" : "";
    var nextDis = agendaPage >= meta.pageCount - 1 ? " is-disabled" : "";
    return ''
      + '<button type="button" class="agenda-pg agenda-pg-prev' + prevDis + '" aria-label="Previous deadlines">‹ prev</button>'
      + '<span class="agenda-pg-status">'
        + meta.pageStart + '–' + meta.pageEnd + ' of ' + meta.total
      + '</span>'
      + '<button type="button" class="agenda-pg agenda-pg-next' + nextDis + '" aria-label="Next deadlines">next ›</button>';
  }

  function mountAgenda() {
    var ag = renderAgenda();
    document.getElementById("agenda").innerHTML = ag.html;
    document.getElementById("agenda-pager").innerHTML = renderAgendaPager(ag);
    document.getElementById("agenda-fns").innerHTML = renderFootnotes(ag.sources);
  }

  // ---------- Reference panels ----------
  function renderShelfDfis() {
    var withRegistry = DFIS.filter(function (d) { return (d.ingo_gp_commits || []).length > 0; }).length;
    var withNetworkOnly = DFIS.filter(function (d) {
      var reg = (d.ingo_gp_commits || []).length;
      var net = (d.slug && NET_LP[d.slug]) || 0;
      return reg === 0 && net > 0;
    }).length;

    var ranked = DFIS.slice().sort(function (a, b) {
      var ac = (a.ingo_gp_commits || []).length;
      var bc = (b.ingo_gp_commits || []).length;
      if (ac !== bc) return bc - ac;
      var ad = a.last_known_activity_date || "";
      var bd = b.last_known_activity_date || "";
      return bd.localeCompare(ad);
    }).slice(0, 7);

    var rows = ranked.map(function (d, i) {
      var commits = (d.ingo_gp_commits || []).length;
      var emf = d.emerging_manager_facility && d.emerging_manager_facility.exists;
      var url = d.stated_thesis_url || d.public_newsroom_url || d.last_known_activity_url || '{{ "/dfis/" | url }}';
      return '<tr><td class="ref-rank">' + pad(i + 1) + '</td>'
        + '<td>'
        + '<div class="ref-name"><a href="' + I.escAttr(url) + '" target="_blank" rel="noopener">' + I.esc(d.name) + '</a></div>'
        + '<div class="ref-meta">' + I.esc(I.countryName(META, d.country))
          + (emf ? '<span class="emf">EMF facility</span>' : '')
          + '</div>'
        + '</td>'
        + '<td class="num"><span class="ref-figure">' + commits + '</span><span class="ref-figure-label">commits</span></td>'
        + '</tr>';
    }).join("");

    var foot = withRegistry + ' of ' + DFIS.length
      + ' have a curated INGO-GP commitment on file';
    if (withNetworkOnly > 0) {
      foot += '; another ' + withNetworkOnly
        + ' surface as LPs on tracked peer impact funds in scraped LP data only';
    }
    foot += '. Remaining rows are DFIs in the registry without a documented commit yet.';

    return '<div class="panel">'
      + '<div class="panel-head"><span class="label">DFIs by INGO-GP commitments</span><a class="tail" href="{{ "/dfis/" | url }}">All ' + DFIS.length + ' →</a></div>'
      + '<table class="ref-list"><tbody>' + rows + '</tbody></table>'
      + '<p class="panel-foot muted">' + foot + '</p>'
      + '</div>';
  }

  var FOUNDATION_TYPE_LABELS = {
    private: "Private", corporate: "Corporate", community: "Community",
    operating: "Operating", public_charity: "Public charity",
    supporting_org: "Supporting org", philanthropy: "Philanthropy LLC"
  };

  // Effective LP-commit count for a registry entry: the larger of the
  // registry's own known_ingo_gp_commits[] field and the count of LP edges
  // in the network graph that resolve to this entry's slug. The registry
  // field is sparse; the network LP edges come from the fund_lps.csv
  // pipeline and every edge carries a public source URL.
  function effectiveCommitCount(d) {
    var registry = (d.known_ingo_gp_commits || []).length;
    var network  = (d.slug && NET_LP[d.slug]) || 0;
    return registry > network ? registry : network;
  }

  function renderShelfFoundations() {
    var withCommits = FDNS.filter(function (d) { return effectiveCommitCount(d) > 0; }).length;
    var ranked = FDNS.slice().sort(function (a, b) {
      var ac = effectiveCommitCount(a);
      var bc = effectiveCommitCount(b);
      if (ac !== bc) return bc - ac;
      var atc = a.typical_check_usd_m_min || 0;
      var btc = b.typical_check_usd_m_min || 0;
      if (atc !== btc) return btc - atc;
      return (a.name || "").localeCompare(b.name || "");
    }).slice(0, 7);

    var rows = ranked.map(function (d, i) {
      var commits = effectiveCommitCount(d);
      var url = d.stated_thesis_url || d.public_newsroom_url || '{{ "/foundations/" | url }}';
      var typeLabel = FOUNDATION_TYPE_LABELS[d.foundation_type] || "";
      var figure, figLabel;
      if (commits > 0) {
        figure = commits;
        figLabel = commits === 1 ? "fund-LP commit" : "fund-LP commits";
      } else if (d.typical_check_usd_m_min != null) {
        var min = d.typical_check_usd_m_min;
        var max = d.typical_check_usd_m_max;
        figure = (max && max !== min) ? '$' + min + '–' + max + 'M' : '$' + min + 'M';
        figLabel = "typical check";
      } else {
        figure = "—";
        figLabel = "no public commit";
      }
      return '<tr><td class="ref-rank">' + pad(i + 1) + '</td>'
        + '<td>'
        + '<div class="ref-name"><a href="' + I.escAttr(url) + '" target="_blank" rel="noopener">' + I.esc(d.name) + '</a></div>'
        + '<div class="ref-meta">' + I.esc(I.countryName(META, d.country))
          + (typeLabel ? '<span class="emf">' + I.esc(typeLabel) + '</span>' : '')
          + '</div>'
        + '</td>'
        + '<td class="num"><span class="ref-figure">' + figure + '</span><span class="ref-figure-label">' + figLabel + '</span></td>'
        + '</tr>';
    }).join("");

    return '<div class="panel">'
      + '<div class="panel-head"><span class="label">Foundations &amp; corporate-impact arms</span><a class="tail" href="{{ "/foundations/" | url }}">All ' + FDNS.length + ' →</a></div>'
      + '<table class="ref-list"><tbody>' + rows + '</tbody></table>'
      + '<p class="panel-foot muted">' + withCommits + ' of ' + FDNS.length + ' have at least one publicly-traceable fund-LP commit (network LP edges + registry field); remaining rows show stated typical-check size where disclosed.</p>'
      + '</div>';
  }

  var FAMILY_OFFICE_CATEGORY_LABELS = {
    family_office: "Family office", faith_based: "Faith-based",
    daf: "DAF", philanthropy_llc: "Philanthropy LLC", hnwi_collective: "HNWI"
  };

  function renderShelfFamilyOffices() {
    var withCommits = FAMOFS.filter(function (d) { return effectiveCommitCount(d) > 0; }).length;
    var ranked = FAMOFS.slice().sort(function (a, b) {
      var ac = effectiveCommitCount(a);
      var bc = effectiveCommitCount(b);
      if (ac !== bc) return bc - ac;
      var atc = a.typical_check_usd_m_min || 0;
      var btc = b.typical_check_usd_m_min || 0;
      if (atc !== btc) return btc - atc;
      return (a.name || "").localeCompare(b.name || "");
    }).slice(0, 7);

    var rows = ranked.map(function (d, i) {
      var commits = effectiveCommitCount(d);
      var url = d.stated_thesis_url || d.public_newsroom_url || '{{ "/family-offices/" | url }}';
      var catLabel = FAMILY_OFFICE_CATEGORY_LABELS[d.category] || "";
      var figure, figLabel;
      if (commits > 0) {
        figure = commits;
        figLabel = commits === 1 ? "fund-LP commit" : "fund-LP commits";
      } else if (d.typical_check_usd_m_min != null) {
        var min = d.typical_check_usd_m_min;
        var max = d.typical_check_usd_m_max;
        figure = (max && max !== min) ? '$' + min + '–' + max + 'M' : '$' + min + 'M';
        figLabel = "typical check";
      } else {
        figure = "—";
        figLabel = "no public commit";
      }
      return '<tr><td class="ref-rank">' + pad(i + 1) + '</td>'
        + '<td>'
        + '<div class="ref-name"><a href="' + I.escAttr(url) + '" target="_blank" rel="noopener">' + I.esc(d.name) + '</a></div>'
        + '<div class="ref-meta">' + I.esc(I.countryName(META, d.country))
          + (catLabel ? '<span class="emf">' + I.esc(catLabel) + '</span>' : '')
          + '</div>'
        + '</td>'
        + '<td class="num"><span class="ref-figure">' + figure + '</span><span class="ref-figure-label">' + figLabel + '</span></td>'
        + '</tr>';
    }).join("");

    return '<div class="panel">'
      + '<div class="panel-head"><span class="label">Family offices, faith-based &amp; philanthropy LLCs</span><a class="tail" href="{{ "/family-offices/" | url }}">All ' + FAMOFS.length + ' →</a></div>'
      + '<table class="ref-list"><tbody>' + rows + '</tbody></table>'
      + '<p class="panel-foot muted">' + withCommits + ' of ' + FAMOFS.length + ' have at least one publicly-traceable fund-LP commit (network LP edges + registry field); remaining rows show stated typical-check size where disclosed.</p>'
      + '</div>';
  }

  function renderShelfPeers() {
    var ranked = PEER.slice().sort(function (a, b) {
      var ad = a.first_close_date || "0000";
      var bd = b.first_close_date || "0000";
      if (ad !== bd) return bd.localeCompare(ad);
      return (b.size_usd_m || 0) - (a.size_usd_m || 0);
    }).slice(0, 7);

    var rows = ranked.map(function (f, i) {
      var url = f.public_source_url || ('{{ "/peer-funds/" | url }}#fund-' + f.slug);
      var size = f.size_usd_m != null ? "$" + f.size_usd_m + "M" : "n/d";
      var dateStr = f.first_close_date ? f.first_close_date.slice(0, 7) : (f.vintage ? String(f.vintage) : "—");
      return '<tr><td class="ref-rank">' + pad(i + 1) + '</td>'
        + '<td>'
        + '<div class="ref-name"><a href="' + I.escAttr(url) + '" target="_blank" rel="noopener">' + I.esc(f.name) + '</a></div>'
        + '<div class="ref-meta">' + I.esc(f.parent_ingo) + ' · ' + I.esc(I.countryName(META, f.parent_ingo_country)) + '</div>'
        + '</td>'
        + '<td class="num"><span class="ref-figure">' + size + '</span><span class="ref-figure-label">' + dateStr + '</span></td>'
        + '</tr>';
    }).join("");

    return '<div class="panel">'
      + '<div class="panel-head"><span class="label">Peer funds by first-close recency</span><a class="tail" href="{{ "/peer-funds/" | url }}">All ' + PEER.length + ' →</a></div>'
      + '<table class="ref-list"><tbody>' + rows + '</tbody></table>'
      + '</div>';
  }

  function renderFootnotes(sources) {
    if (!sources || sources.length === 0) return "";
    return sources.map(function (url, i) {
      var host = "";
      try { host = new URL(url).host.replace(/^www\./, ""); } catch (e) { host = url; }
      return '<span><span class="fn-num">' + (i + 1) + '</span><a href="' + I.escAttr(url) + '" target="_blank" rel="noopener">' + I.esc(host) + '</a></span>';
    }).join("");
  }

  // ---------- Mount ----------
  document.getElementById("data-ribbon").innerHTML = renderRibbon();
  mountAgenda();
  document.getElementById("shelf-dfis").innerHTML        = renderShelfDfis();
  document.getElementById("shelf-foundations").innerHTML = renderShelfFoundations();
  document.getElementById("shelf-famofs").innerHTML      = renderShelfFamilyOffices();
  document.getElementById("shelf-peers").innerHTML       = renderShelfPeers();

  // Impact-areas chart — homepage variant: 3y "active DFI" filter is locked on.
  var IMPACT = I.loadJSON("data-impact-areas") || [];
  var icChart  = document.getElementById("ic-home-chart");
  var icDrawer = document.getElementById("ic-home-drawer");
  if (icChart && IMPACT.length > 0) {
    I.renderImpactChart(icChart, icDrawer, IMPACT, { useActive: true, useCalling: true, openFirst: false });
  }

  // Whole-row click on agenda (delegated)
  var agendaEl = document.getElementById("agenda");
  agendaEl.addEventListener("click", function (evt) {
    if (evt.target.closest("a")) return;
    var row = evt.target.closest("tr.card-clickable");
    if (!row) return;
    var url = row.getAttribute("data-source-url");
    if (url) window.open(url, "_blank", "noopener,noreferrer");
  });

  // Agenda pagination
  document.getElementById("agenda-pager").addEventListener("click", function (evt) {
    var btn = evt.target.closest(".agenda-pg");
    if (!btn || btn.classList.contains("is-disabled")) return;
    if (btn.classList.contains("agenda-pg-prev")) agendaPage = Math.max(0, agendaPage - 1);
    if (btn.classList.contains("agenda-pg-next")) agendaPage = agendaPage + 1;
    mountAgenda();
  });

  // Whole-column click → section landing page (skip inner links).
  function makeColClickable(col) {
    if (!col) return;
    var link = col.querySelector(".sec-link");
    if (!link) return;
    col.classList.add("home-col-clickable");
    col.addEventListener("click", function (evt) {
      if (evt.target.closest("a")) return;
      if (evt.metaKey || evt.ctrlKey || evt.shiftKey || evt.button === 1) {
        window.open(link.href, "_blank", "noopener,noreferrer");
      } else {
        window.location.href = link.href;
      }
    });
  }
  makeColClickable(document.querySelector(".home-col-network"));
  makeColClickable(document.querySelector(".home-col-catalysts"));
})();
</script>
