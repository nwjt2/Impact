---
layout: base.njk
title: Corporates
permalink: /corporates/index.html
pageKey: corporates
---

<section class="detail-page">
  <p class="back-link"><a href="{{ '/' | url }}">← Back to index</a></p>
  <header class="detail-header">
    <div class="detail-eyebrow">
      <span>Capital sources · operating corporates as fund LPs</span>
    </div>
    <h1>Operating corporates observed as LPs in peer impact funds.</h1>
    <p class="detail-sub">{{ corporate_lps | length }} profiles. Most corporate fund-LP commitments are tied to a specific ESG / supply-chain / brand initiative rather than a standing allocation. Stated theses at the fund-LP level are almost never published — expect heavy null coverage. The corresponding corporate foundation (e.g. Mastercard Foundation, MetLife Foundation) is tracked separately on /foundations/ — corporate balance sheet ≠ corporate foundation endowment.</p>
  </header>

  <div class="filter-bar">
    <label class="filter-label" for="country-filter">Country</label>
    <select id="country-filter" class="filter-select"></select>
    <label class="filter-label" for="cat-filter">Sector</label>
    <select id="cat-filter" class="filter-select">
      <option value="ALL">All sectors</option>
      <option value="consumer">Consumer</option>
      <option value="industrial">Industrial</option>
      <option value="pharma">Pharma / health</option>
      <option value="tech">Technology</option>
      <option value="retail">Retail</option>
      <option value="financial_services">Financial services</option>
    </select>
    <span id="filter-summary" class="filter-summary"></span>
  </div>

  <div id="lp-list" class="dfi-list" aria-live="polite"></div>
  <div id="lp-empty" class="empty-state" hidden></div>
</section>

<script type="application/json" id="data-lps">{{ corporate_lps | dump | safe }}</script>
<script type="application/json" id="data-slot-meta">{{ slot_meta | dump | safe }}</script>
<script type="application/json" id="data-net-lp-funds">{{ network_lp_summary.lpFundsBySlug | dump | safe }}</script>

<script src="{{ '/assets/js/render.js' | url }}"></script>
<script>
(function () {
  "use strict";
  var I = window.IFC;
  var LPS = I.loadJSON("data-lps") || [];
  var META = I.loadJSON("data-slot-meta") || {};
  var NET_LP = I.loadJSON("data-net-lp-funds") || {};

  LPS.forEach(function (d) {
    if (d.slug && NET_LP[d.slug]) d._network_lp_funds = NET_LP[d.slug];
  });
  function netLpCount(d) { return (d._network_lp_funds || []).length; }

  var state = { country: "ALL", category: "ALL" };

  function render() {
    var list = LPS.filter(function (d) {
      if (state.country !== "ALL" && d.country !== state.country) return false;
      if (state.category !== "ALL" && d.category !== state.category) return false;
      return true;
    });
    list.sort(function (a, b) {
      var ac = netLpCount(a), bc = netLpCount(b);
      if (ac !== bc) return bc - ac;
      return (a.name || "").localeCompare(b.name || "");
    });

    var root = document.getElementById("lp-list");
    var empty = document.getElementById("lp-empty");
    var sum = document.getElementById("filter-summary");

    if (list.length === 0) {
      root.innerHTML = "";
      empty.hidden = false;
      empty.innerHTML = "<p>No corporates match this filter.</p>";
      sum.textContent = "Showing 0 of " + LPS.length;
      return;
    }
    empty.hidden = true; empty.innerHTML = "";
    root.innerHTML = list.map(function (d) { return I.renderSimpleLpCard(d, META, "corporate"); }).join("");
    sum.textContent = "Showing " + list.length + " of " + LPS.length;
  }

  var observedCountries = {};
  LPS.forEach(function (d) { if (d.country) observedCountries[d.country] = (observedCountries[d.country] || 0) + 1; });
  var sel = document.getElementById("country-filter");
  var options = ['<option value="ALL">All countries (' + LPS.length + ')</option>'];
  Object.keys(observedCountries).sort().forEach(function (c) {
    options.push('<option value="' + I.escAttr(c) + '">' + I.esc(I.countryName(META, c)) + ' (' + observedCountries[c] + ')</option>');
  });
  sel.innerHTML = options.join("");
  sel.addEventListener("change", function (e) { state.country = e.target.value; render(); });
  document.getElementById("cat-filter").addEventListener("change", function (e) { state.category = e.target.value; render(); });

  I.installCardClick(".detail-page");
  render();
})();
</script>
